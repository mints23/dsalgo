            const isProblemTable = tbl && tbl.querySelector('.num-cell');
            const txt = el.textContent || '';
            const isProblemHeading = (el.classList.contains('sec-title') || /^H[1-6]$/.test(el.tagName))
              && (/problem\s*set/i.test(txt) || /section\s*[A-Z]/i.test(txt));
            if (w98Active) {
              if (isProblemTable || isProblemHeading) {
                el.style.setProperty('display', isProblemTable ? 'block' : '', 'important');
              } else {
                el.style.setProperty('display', 'none', 'important');
