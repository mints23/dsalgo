                        <tr><td>Count overlaps (sweep)</td><td>O(n log n)</td><td>O(n)</td><td>Sort events</td></tr>
                        <tr><td>Interval removal (greedy)</td><td>O(n log n)</td><td>O(1) extra</td><td>Sort by end</td></tr>
                        <tr><td>Interval coverage (greedy)</td><td>O(n log n)</td><td>O(1) extra</td><td>Sort by start</td></tr>
                        <tr><td>Gap detection</td><td>O(n log n)</td><td>O(n)</td><td>Sort + linear scan</td></tr>
                        <tr><td>Interval intersection</td><td>O(m + n)</td><td>O(m + n)</td><td>Two-pointer</td></tr>
                        <tr><td>Interval subtraction</td><td>O(n)</td><td>O(n)</td><td>Linear scan</td></tr>
                        <tr><td>Weighted job scheduling</td><td>O(n log n)</td><td>O(n)</td><td>DP + binary search</td></tr>
