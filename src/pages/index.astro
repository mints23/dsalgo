---
import '../styles/global.css';
import LogoMark from '../components/LogoMark.astro';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Apply theme before paint: saved pref → OS pref → light
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1f5c61" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>DSA Mastery Guide</title>
    <meta name="description" content="Comprehensive DSA interview preparation guide with 1150+ problems across 43 topics — Two Pointers, Binary Search, DP, Graphs, and more." />
    <meta property="og:title" content="DSA Mastery Guide — algofrog.in" />
    <meta property="og:description" content="Comprehensive DSA interview preparation guide with 1150+ problems across 43 topics." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://algofrog.in" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="DSA Mastery Guide — algofrog.in" />
    <meta name="twitter:description" content="1150+ problems across 43 DSA topics for interview prep." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-RKMP4BG1N2"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-RKMP4BG1N2');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@300..700&display=swap"
      rel="stylesheet"
    />
    <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>
  </head>
  <body>
    <!-- Shell only — NO topic data in the HTML. Content fetched from Supabase after auth. -->
    <div class="app" style="visibility:hidden">
      <nav class="sidebar" id="sidebar">
        <div class="logo">
          <LogoMark width={28} height={28} />
          <div>
            <div class="logo-text">DSA Mastery</div>
            <div class="logo-sub">Interview Preparation Guide</div>
          </div>
        </div>
        <div id="nav-list"></div>
        <div class="sidebar-footer">
          <button class="theme-btn" aria-label="Toggle theme">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            Theme
          </button>
          <span class="progress-summary" id="topic-count"></span>
        </div>
      </nav>

      <div class="main">
        <div class="topbar">
          <div>
            <div class="topbar-title" id="topbar-title"></div>
            <div class="topbar-meta" id="topbar-meta"></div>
          </div>
          <div class="overall-progress" id="overall-progress" title="Overall progress" style="min-width:120px;max-width:180px;">
            <div class="overall-progress-bar"><div class="overall-progress-fill" id="overall-fill"></div></div>
            <span class="overall-progress-text" id="overall-text">0/0</span>
          </div>

          <div class="streak-mini" id="daily-streak-card" hidden aria-label="7 day streak">
            <div class="streak-mini-days" id="daily-streak-row" aria-label="Solved in the last 7 days"></div>
            <button type="button" class="streak-mini-meta" id="daily-streak-meta" title="Streak + last 7 days">
              —
            </button>
            <button type="button" class="streak-mini-btn" id="streak-open-year" title="Open year heatmap">
              Year
            </button>
          </div>

          <div style="display:flex;align-items:center;gap:0.4rem;">
            <span id="user-name" style="font-size:0.78rem;color:var(--muted);font-weight:500;margin-right:0.3rem;"></span>
            <button class="theme-btn-top" id="theme-toggle-top" aria-label="Toggle theme">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="5" />
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
              </svg>
            </button>
            <button class="theme-btn-top" id="logout-btn" aria-label="Sign out" title="Sign out">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                <polyline points="16 17 21 12 16 7" />
                <line x1="21" y1="12" x2="9" y2="12" />
              </svg>
            </button>
          </div>
        </div>
        <div class="pro-benefits-strip" id="pro-benefits-strip" hidden>
          <div class="pro-benefits-strip-layout">
            <details class="pro-benefits-details" title="What you get with Pro">
              <summary class="pro-benefits-summary">
                <span class="pro-benefits-badge">Pro</span>
                <span class="pro-benefits-summary-line">
                  <span class="pro-benefits-kw">Progress</span><span class="pro-benefits-sep">·</span><span class="pro-benefits-kw">Focus</span><span class="pro-benefits-sep">·</span><span class="pro-benefits-kw">Animated insights</span>
                  <span class="pro-benefits-summary-hint">details</span>
                </span>
                <span class="pro-benefits-chevron" aria-hidden="true">▾</span>
              </summary>
            <div class="pro-benefits-body">
              <p class="pro-benefits-lead">
                Pro is for people grinding the list: you keep <strong>state</strong> (what you solved), <strong>access</strong> (every topic after trial), and <strong>animated insight walkthroughs</strong> (step-by-step playback with pacing and speed) — not just read-only pages.
              </p>
              <div class="pro-benefit-grid" role="list">
                <div class="pro-benefit-point" role="listitem">
                  <span class="pro-benefit-icon pro-benefit-icon--a" aria-hidden="true">1</span>
                  <div class="pro-benefit-copy">
                    <span class="pro-benefit-title">Clear picture of progress</span>
                    <p class="pro-benefit-desc">Tick problems as you go; the nav dots and top bar show how deep you are in each topic. Everything syncs to your login — switch laptop or phone without starting from zero.</p>
                  </div>
                </div>
                <div class="pro-benefit-point" role="listitem">
                  <span class="pro-benefit-icon pro-benefit-icon--b" aria-hidden="true">2</span>
                  <div class="pro-benefit-copy">
                    <span class="pro-benefit-title">Strip noise, keep signal</span>
                    <p class="pro-benefit-desc"><strong>Problems only</strong> hides long explanations when you just want the table. <strong>Core set</strong> narrows each topic to minimum-coverage rows. Both follow your account so your next session matches this one.</p>
                  </div>
                </div>
                <div class="pro-benefit-point" role="listitem">
                  <span class="pro-benefit-icon pro-benefit-icon--c" aria-hidden="true">3</span>
                  <div class="pro-benefit-copy">
                    <span class="pro-benefit-title">The whole 43-topic path stays open</span>
                    <p class="pro-benefit-desc">Trial ends or access lapses — without Pro you drop to free chapters only. Pro keeps the full structured guide (tables, layers, and every problem row) so your prep isn’t fragmented.</p>
                  </div>
                </div>
                <div class="pro-benefit-point" role="listitem">
                  <span class="pro-benefit-icon pro-benefit-icon--d" aria-hidden="true">4</span>
                  <div class="pro-benefit-copy">
                    <span class="pro-benefit-title">Animated key-insight playback</span>
                    <p class="pro-benefit-desc">Click any <strong>Key insight</strong> cell for the full overlay: curated steps, typewriter-style code replay, auto-advance, speed control, and visual frames where we ship them. It’s included with Pro so you can rehearse each problem’s story end to end.</p>
                  </div>
                </div>
              </div>
              <div class="pro-benefits-actions">
                <button type="button" class="pro-benefits-upgrade" id="pro-benefits-upgrade">
                  Go Pro — ₹149/mo
                </button>
                <span class="pro-benefits-footnote">₹299 / 3 mo also available at checkout</span>
              </div>
            </div>
            </details>
            <button
              type="button"
              class="pro-benefits-dismiss"
              id="pro-benefits-dismiss"
              aria-label="Hide Pro banner until next visit"
              title="Hide until next visit"
            >
              ×
            </button>
          </div>
        </div>
        <div class="guide-method-strip" id="guide-method-strip">
          <div class="guide-method-strip-layout">
            <details class="guide-method-details">
              <summary class="guide-method-summary">
                <span class="guide-method-badge">Method</span>
                <div class="guide-method-summary-main">
                  <span class="guide-method-tagline">Solve in sequence</span>
                  <p class="guide-method-blurb">
                    Each problem introduces a new challenge on top of what you already practiced—systematic mastery, not random order.
                  </p>
                  <span class="guide-method-summary-hint">Why sequence matters</span>
                </div>
                <span class="guide-method-chevron" aria-hidden="true">▾</span>
              </summary>
              <div class="guide-method-body">
                <p class="guide-method-lede">
                  Inside every topic table, rows are <strong>ordered on purpose</strong>: each question adds something you have not yet tackled in the rows above, while building on the skills you just used. That stacked ladder is the most <strong>methodical path to mastering the topic</strong>—learning accumulates step by step instead of skipping around.
                </p>
              </div>
            </details>
            <button
              type="button"
              class="guide-method-dismiss"
              id="guide-method-dismiss"
              aria-label="Hide this note until next visit"
              title="Hide until next visit"
            >
              ×
            </button>
          </div>
        </div>
        <div class="heatmap-modal" id="heatmap-modal" aria-modal="true" role="dialog" aria-labelledby="heatmap-modal-title" hidden>
          <div class="heatmap-modal-inner">
            <div class="heatmap-modal-head">
              <div class="heatmap-modal-title">
                <div class="heatmap-modal-title-main" id="heatmap-modal-title">Daily solved</div>
                <div class="heatmap-modal-title-sub" id="heatmap-modal-subtitle">—</div>
              </div>
              <button type="button" class="heatmap-modal-close" id="heatmap-modal-close" aria-label="Close year view">✕</button>
            </div>
            <div class="heatmap-modal-body">
              <div class="heatmap-months" id="daily-heatmap-months" aria-hidden="true"></div>
              <div class="heatmap-grid-wrap heatmap-grid-wrap--modal">
                <div class="heatmap-weekdays" aria-hidden="true">
                  <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                </div>
                <div class="heatmap-grid" id="daily-heatmap-grid" role="grid" aria-label="Daily solved heatmap"></div>
              </div>
              <div class="heatmap-legend" aria-hidden="true">
                <span class="heatmap-legend-lbl">Less</span>
                <span class="heatmap-swatch heatmap-l0"></span>
                <span class="heatmap-swatch heatmap-l1"></span>
                <span class="heatmap-swatch heatmap-l2"></span>
                <span class="heatmap-swatch heatmap-l3"></span>
                <span class="heatmap-swatch heatmap-l4"></span>
                <span class="heatmap-legend-lbl">More</span>
              </div>
              <div class="heatmap-meta" id="daily-heatmap-meta"></div>
            </div>
          </div>
        </div>
        <div class="content" id="content"></div>
      </div>

      <button class="mob-nav-btn" id="mob-nav-btn" aria-label="Open navigation">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
    <!-- ── Key Insight overlay (shared, single instance) ── -->
    <div id="insight-overlay" class="insight-overlay" aria-modal="true" role="dialog" aria-labelledby="insight-overlay-title">
      <div class="insight-modal">
        <div class="insight-modal-accent" aria-hidden="true"></div>
        <div class="insight-header">
          <div class="insight-header-main">
            <span class="insight-lc-badge"></span>
            <div class="insight-header-body">
              <span class="insight-title" id="insight-overlay-title"></span>
              <div class="insight-header-chips" aria-label="Complexity">
                <span class="insight-chip insight-chip--kind">Key insight</span>
                <span class="insight-chip" title="Time">⏱&nbsp;<span class="insight-chip-time">—</span></span>
                <span class="insight-chip" title="Space">💾&nbsp;<span class="insight-chip-space">—</span></span>
              </div>
            </div>
          </div>
          <button type="button" class="insight-close" aria-label="Close walkthrough">✕</button>
        </div>
        <div class="insight-panel">
          <!-- 1. Visualization view: animated array + pointer frames (solo mode, or “Example” beside solution) -->
          <div class="viz-view">
            <div class="viz-example-badge">Example</div>
            <div class="viz-step-label"></div>
            <div class="viz-frame-wrap"></div>
            <div class="viz-frame-note"></div>
          </div>
          <!-- 2. Solution view: pseudocode + side-by-side dry run -->
          <div class="sol-view">
            <div class="sol-split">
              <div class="sol-split-main">
                <div class="sol-step-title"></div>
                <div class="sol-word-code">
                  <div class="sol-prose-col">
                    <div class="sol-prose-label">Summary</div>
                    <div class="sol-explain"></div>
                  </div>
                  <div class="sol-code-col">
                    <div class="sol-code-label">Code</div>
                    <pre class="sol-code"></pre>
                  </div>
                </div>
                <div class="sol-note"></div>
              </div>
              <aside class="sol-split-dry" aria-label="Numbers and state for this step">
                <div class="sol-dry-head">Data · this step</div>
                <div class="sol-dry-caption"></div>
                <div class="sol-dry-frame"></div>
                <pre class="sol-dry-aux"></pre>
              </aside>
            </div>
          </div>
          <!-- 3. Text fallback -->
          <div class="insight-steps"></div>
        </div>
        <!-- Shared prev/play/next controls used by viz + sol modes -->
        <div class="overlay-controls">
          <div class="sol-dots"></div>
          <label class="speed-ctl">
            <span class="speed-ctl-lbl">Speed</span>
            <select id="insight-speed" class="speed-ctl-select" aria-label="Playback speed" title="Applies to auto-advance, typing, pauses between steps, and note fade">
              <option value="0.5">0.5×</option>
              <option value="1" selected>1×</option>
              <option value="1.5">1.5×</option>
              <option value="2">2×</option>
              <option value="3">3×</option>
            </select>
          </label>
          <div class="sol-btns">
            <button class="sol-btn sol-prev" aria-label="Previous">&#8592;</button>
            <button class="sol-btn sol-playpause" aria-label="Play/Pause">&#9654;</button>
            <button class="sol-btn sol-next" aria-label="Next">&#8594;</button>
          </div>
          <div class="sol-counter"></div>
        </div>
      </div>
    </div>

    <!-- Pro gate: walkthrough included with Pro -->
    <div
      id="insight-pro-gate"
      class="insight-overlay"
      aria-modal="true"
      role="dialog"
      aria-labelledby="insight-pro-gate-heading"
      aria-hidden="true"
    >
      <div class="insight-modal insight-pro-gate-modal">
        <div class="insight-modal-accent" aria-hidden="true"></div>
        <div class="insight-pro-gate-head">
          <div class="insight-pro-gate-head-text">
            <p class="insight-pro-gate-lc"></p>
            <h2 id="insight-pro-gate-heading" class="insight-pro-gate-title"></h2>
          </div>
          <button type="button" class="insight-close insight-pro-gate-close" aria-label="Close">✕</button>
        </div>
        <div class="insight-pro-gate-body">
          <p class="insight-pro-gate-copy">
            Go Pro to open the full key-insight walkthrough: curated steps, visuals where we ship them, and playback you can run at your own pace.
          </p>
          <button type="button" class="pro-benefits-upgrade" id="insight-pro-gate-upgrade">Go Pro — ₹149/mo</button>
          <p class="insight-pro-gate-foot">₹299 / 3 mo also available at checkout</p>
        </div>
      </div>
    </div>

    <div style="text-align:center;padding:0.6rem;font-size:0.72rem;color:var(--muted);">
      Need help? <a href="mailto:algofrog07@gmail.com" style="color:var(--primary);text-decoration:none;font-weight:600;">algofrog07@gmail.com</a>
    </div>
    <script>
      import { supabase } from '../lib/supabase';
      import { getStepExplain, stepHasProseAside } from '../data/step-explain';
      import { resolvePlaybackComplexity } from '../data/playback-complexity';

      // ── Auth Gate ──
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) { window.location.href = '/login'; throw new Error('redirect'); }

      // ── Trial / Subscription Check ──
      let { data: sub } = await supabase
        .from('subscriptions')
        .select('status, trial_ends_at, paid_until')
        .eq('user_id', session.user.id)
        .single();

      // Existing users without a subscription row get a 7-day trial
      if (!sub) {
        const { data: newSub } = await supabase
          .from('subscriptions')
          .insert({ user_id: session.user.id, status: 'trial', trial_ends_at: new Date(Date.now() + 7 * 86400000).toISOString() })
          .select('status, trial_ends_at, paid_until')
          .single();
        sub = newSub;
      }

      const now = new Date();
      const isTrialActive = sub?.status === 'trial' && new Date(sub.trial_ends_at) > now;
      const isPaid = sub?.status === 'active' && sub.paid_until && new Date(sub.paid_until) > now;
      const isExpired = !isTrialActive && !isPaid;

      type PayPlan = 'monthly' | 'quarterly';

      // Display user name + status badge
      const userName = session.user.user_metadata?.full_name || session.user.email?.split('@')[0] || '';
      const userNameEl = document.getElementById('user-name')!;
      if (isTrialActive) {
        const daysLeft = Math.ceil((new Date(sub!.trial_ends_at).getTime() - now.getTime()) / 86400000);
        userNameEl.innerHTML = `${userName} <span style="font-size:0.68rem;color:var(--warning, #e6a817);font-weight:600;margin-left:0.3rem;">Trial: ${daysLeft}d left</span>`;
        const trialBtns = document.createElement('span');
        trialBtns.style.cssText = 'display:inline-flex;gap:0.3rem;margin-left:0.35rem;flex-wrap:wrap;align-items:center;';
        const mkTrialPay = (label: string, plan: 'monthly' | 'quarterly') => {
          const b = document.createElement('button');
          b.textContent = label;
          b.style.cssText =
            'font-size:0.65rem;padding:0.22rem 0.5rem;border-radius:0.3rem;background:var(--primary);color:var(--inv);border:none;cursor:pointer;font-weight:600;';
          b.addEventListener('click', () => openRazorpay(plan));
          return b;
        };
        trialBtns.appendChild(mkTrialPay('₹149/mo', 'monthly'));
        trialBtns.appendChild(mkTrialPay('₹299/3 mo', 'quarterly'));
        userNameEl.parentElement!.insertBefore(trialBtns, userNameEl.nextSibling);
      } else if (isPaid) {
        const paidDaysLeft = Math.ceil((new Date(sub!.paid_until!).getTime() - now.getTime()) / 86400000);
        userNameEl.innerHTML = `${userName} <span style="display:inline-flex;align-items:center;gap:0.25rem;font-size:0.68rem;font-weight:700;margin-left:0.4rem;padding:0.15rem 0.5rem;border-radius:1rem;background:linear-gradient(135deg,#01696f,#02a6a0);color:#fff;box-shadow:0 1px 4px rgba(1,105,111,0.3);letter-spacing:0.02em;">&#9733; PRO &middot; ${paidDaysLeft}d</span>`;
      } else {
        // Expired: show banner + upgrade choices
        userNameEl.innerHTML = `${userName} <span style="font-size:0.68rem;color:#e53e3e;font-weight:700;margin-left:0.3rem;">Trial Ended</span>`;
        const expBtns = document.createElement('span');
        expBtns.style.cssText = 'display:inline-flex;gap:0.3rem;margin-left:0.35rem;flex-wrap:wrap;align-items:center;';
        const mkExp = (label: string, plan: PayPlan) => {
          const b = document.createElement('button');
          b.textContent = label;
          b.style.cssText =
            'font-size:0.65rem;padding:0.24rem 0.55rem;border-radius:0.3rem;background:linear-gradient(135deg,#01696f,#02a6a0);color:#fff;border:none;cursor:pointer;font-weight:700;box-shadow:0 1px 6px rgba(1,105,111,0.35);';
          b.addEventListener('click', () => openRazorpay(plan));
          return b;
        };
        expBtns.appendChild(mkExp('₹149/mo', 'monthly'));
        expBtns.appendChild(mkExp('₹299/3 mo', 'quarterly'));
        userNameEl.parentElement!.insertBefore(expBtns, userNameEl.nextSibling);
      }

      // ── Razorpay Checkout ──
      function openRazorpay(plan: PayPlan = 'monthly') {
        const amounts: Record<PayPlan, number> = { monthly: 14900, quarterly: 29900 };
        const descriptions: Record<PayPlan, string> = {
          monthly: 'DSA Mastery Guide — Monthly (₹149)',
          quarterly: 'DSA Mastery Guide — Quarterly 3 months (₹299)',
        };
        const options = {
          key: import.meta.env.PUBLIC_RAZORPAY_KEY_ID,
          amount: amounts[plan],
          currency: 'INR',
          name: 'algofrog.in',
          description: descriptions[plan],
          prefill: {
            email: session.user.email,
            name: session.user.user_metadata?.full_name || '',
          },
          theme: { color: '#01696f' },
          handler: async (response: any) => {
            const { data, error } = await supabase.rpc('activate_subscription', {
              payment_id: response.razorpay_payment_id,
              plan,
            });
            if (error) {
              alert('Payment recorded but activation failed. Please contact support.');
              console.error(error);
            } else {
              alert('🎉 Payment successful! Your Pro subscription is now active. Thank you for subscribing to DSA Mastery Guide.');
              window.location.reload();
            }
          },
        };
        const rzp = new (window as any).Razorpay(options);
        rzp.open();
      }

      const insightProGate = document.getElementById('insight-pro-gate')!;
      const insightProGateLc = insightProGate.querySelector<HTMLElement>('.insight-pro-gate-lc')!;
      const insightProGateTitle = insightProGate.querySelector<HTMLElement>('.insight-pro-gate-title')!;
      function openInsightProGate(lcNum: string, title: string) {
        insightProGateLc.textContent = lcNum ? `LC ${lcNum}` : '';
        insightProGateTitle.textContent = title || 'Key insight walkthrough';
        insightProGate.classList.add('active');
        insightProGate.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      function closeInsightProGate() {
        insightProGate.classList.remove('active');
        insightProGate.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
      insightProGate.addEventListener('click', (e) => {
        if (e.target === insightProGate) closeInsightProGate();
      });
      insightProGate.querySelector('.insight-pro-gate-close')!.addEventListener('click', closeInsightProGate);
      document.getElementById('insight-pro-gate-upgrade')!.addEventListener('click', () => {
        closeInsightProGate();
        openRazorpay('monthly');
      });
      document.addEventListener(
        'keydown',
        (e) => {
          if (e.key !== 'Escape') return;
          if (!insightProGate.classList.contains('active')) return;
          closeInsightProGate();
        },
        true
      );

      const PRO_STRIP_DISMISS_KEY = 'pro_benefits_strip_dismiss';
      const proBenefitsStrip = document.getElementById('pro-benefits-strip');
      if (!isPaid && proBenefitsStrip && sessionStorage.getItem(PRO_STRIP_DISMISS_KEY) !== '1') {
        proBenefitsStrip.hidden = false;
        proBenefitsStrip.classList.toggle('pro-benefits-strip--trial', isTrialActive);
        document.getElementById('pro-benefits-upgrade')?.addEventListener('click', (e) => {
          e.preventDefault();
          openRazorpay('monthly');
        });
        document.getElementById('pro-benefits-dismiss')?.addEventListener('click', () => {
          sessionStorage.setItem(PRO_STRIP_DISMISS_KEY, '1');
          proBenefitsStrip.hidden = true;
        });
      }

      const GUIDE_METHOD_DISMISS_KEY = 'guide_method_strip_dismiss';
      const guideMethodStrip = document.getElementById('guide-method-strip');
      if (guideMethodStrip) {
        if (sessionStorage.getItem(GUIDE_METHOD_DISMISS_KEY) === '1') {
          guideMethodStrip.hidden = true;
        }
        document.getElementById('guide-method-dismiss')?.addEventListener('click', () => {
          sessionStorage.setItem(GUIDE_METHOD_DISMISS_KEY, '1');
          guideMethodStrip.hidden = true;
        });
      }

      document.getElementById('logout-btn')!.addEventListener('click', async () => {
        await supabase.auth.signOut(); window.location.href = '/login';
      });
      supabase.auth.onAuthStateChange((event) => {
        if (event === 'SIGNED_OUT') window.location.href = '/login';
      });

      // ── Fetch topics from Supabase (RLS: auth only) ──
      const { data: topics, error } = await supabase
        .from('topics')
        // Explicitly exclude body_html from topics — content lives in topic_content now.
        // RLS on topic_content and problems restricts what expired users receive.
        .select('id, display_number, show_in_sidebar, nav_section, nav_label, nav_tier_dot_color, title, tier_code, tier_label, type_label, summary_meta, topbar_meta, topic_content(why_it_matters, core_idea, pattern_triggers, coverage_problems, red_flags), problems(id, order_num, layer, lc_number, lc_url, title, difficulty, is_premium, sub_variant, key_insight)')
        .order('id');
      if (error || !topics?.length) {
        document.body.innerHTML = `<p style="padding:2rem;color:var(--error)">Failed to load content. ${error?.message || 'No topics returned.'}</p>`;
        throw new Error(error?.message || 'No topics');
      }

      // ── Study preferences: Pro loads/saves to Supabase; non-Pro sees toggles disabled (no effect) ──
      const LS_STUDY_PROBLEMS = 'study_problems_only';
      const LS_STUDY_MIN = 'study_min_by_topic';
      const LS_STUDY_REV = 'study_rev_only_by_topic';

      let studyProblemsOnlyPref = false;
      let studyMinByTopic: Record<string, boolean> = {};
      let studyRevOnlyByTopic: Record<string, boolean> = {};

      function loadStudyPrefsFromLocal() {
        try {
          const p = localStorage.getItem(LS_STUDY_PROBLEMS);
          const legacyW98 = localStorage.getItem('w98mode');
          studyProblemsOnlyPref = p === 'true' || (p === null && legacyW98 === 'true');
          const raw = localStorage.getItem(LS_STUDY_MIN);
          const parsed = raw ? JSON.parse(raw) : {};
          studyMinByTopic = {};
          if (parsed && typeof parsed === 'object' && !Array.isArray(parsed)) {
            for (const [k, v] of Object.entries(parsed)) {
              if (v === true) studyMinByTopic[k] = true;
            }
          }
          const rawRev = localStorage.getItem(LS_STUDY_REV);
          const parsedRev = rawRev ? JSON.parse(rawRev) : {};
          studyRevOnlyByTopic = {};
          if (parsedRev && typeof parsedRev === 'object' && !Array.isArray(parsedRev)) {
            for (const [k, v] of Object.entries(parsedRev)) {
              if (v === true) studyRevOnlyByTopic[k] = true;
            }
          }
        } catch (_) {
          studyMinByTopic = {};
          studyRevOnlyByTopic = {};
        }
      }

      function normalizeMinMap(raw: unknown): Record<string, boolean> {
        const out: Record<string, boolean> = {};
        if (raw && typeof raw === 'object' && !Array.isArray(raw)) {
          for (const [k, v] of Object.entries(raw as Record<string, unknown>)) {
            if (v === true) out[k] = true;
          }
        }
        return out;
      }

      if (isPaid) {
        const { data: sp } = await supabase
          .from('user_study_preferences')
          .select('problems_only, min_coverage_by_topic, revision_only_by_topic')
          .eq('user_id', session.user.id)
          .maybeSingle();
        if (sp) {
          studyProblemsOnlyPref = Boolean(sp.problems_only);
          studyMinByTopic = normalizeMinMap(sp.min_coverage_by_topic);
          studyRevOnlyByTopic = normalizeMinMap(sp.revision_only_by_topic);
        } else {
          loadStudyPrefsFromLocal();
        }
      } else {
        studyProblemsOnlyPref = false;
        studyMinByTopic = {};
        studyRevOnlyByTopic = {};
      }

      let persistStudyTimer = 0;
      function schedulePersistStudyPrefs() {
        if (!isPaid) return;
        window.clearTimeout(persistStudyTimer);
        persistStudyTimer = window.setTimeout(async () => {
          const { error: pe } = await supabase.from('user_study_preferences').upsert(
            {
              user_id: session.user.id,
              problems_only: w98Active,
              min_coverage_by_topic: studyMinByTopic,
              revision_only_by_topic: studyRevOnlyByTopic,
              updated_at: new Date().toISOString(),
            },
            { onConflict: 'user_id' },
          );
          if (pe) console.error('Failed to save study preferences:', pe);
        }, 450);
      }

      // Lock detection is DB-driven: topic_content is null when RLS withheld it (expired user, non-free topic).

      /** Plain text for heuristics (topic meta is usually plain; tolerate simple HTML). */
      function metaPlainForTags(s: string): string {
        return (s || '')
          .replace(/<br\s*\/?>/gi, ' ')
          .replace(/<[^>]+>/g, ' ')
          .replace(/&nbsp;/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();
      }

      /**
       * In the DP nav section, "Dynamic Programming · …" repeats the section name.
       * Strip that prefix (and bare "Dynamic Programming" alone). Requires real punctuation
       * after "Programming" so we do not strip titles like "Dynamic Programming Techniques".
       * Normalizes look-alike bullets (∙ • ․ etc.).
       */
      function stripDpNavSectionNoise(s: string): string {
        if (!s) return s;
        let out = s.trim();
        if (/^dynamic\s+programming$/i.test(metaPlainForTags(out))) return '';
        out = out.replace(
          /[\u2219\u2022\u2024\u2027\u30FB\u0387\u22C5\uFF65\u2023\u2043\u2E31\u2E33]/g,
          '\u00B7',
        );
        // "Programming" then optional space, then one+ punctuation tokens (middot, colon, dash, etc.).
        const re =
          /^Dynamic\s+Programming\b(?:[\s\u00A0]*(?:\u00B7|·|&middot;|&#183;|&#8226;|:|[\u2013\u2014\-/,;\\|]|&nbsp;))+[\s\u00A0]*/iu;
        for (let i = 0; i < 6; i++) {
          const next = out.replace(re, '').trim();
          if (next === out) break;
          out = next;
          if (/^dynamic\s+programming$/i.test(metaPlainForTags(out))) return '';
        }
        return out;
      }

      /** Same as stripDpNavSectionNoise for each line or HTML br chunk (multi-line topic-meta). */
      function stripDpNavSectionNoiseDeep(s: string): string {
        if (!s) return s;
        const parts = s.split(/(\r?\n|<br\s*\/?>)/gi);
        return parts
          .map((part) => {
            if (/^\r?\n$/i.test(part) || /^<br/i.test(part)) return part;
            return stripDpNavSectionNoise(part);
          })
          .join('');
      }

      // ── Build Sidebar ──
      const sectionOrder = ['Algorithms', 'Data Structures', 'Dynamic Programming', 'Graphs', 'Advanced Techniques'];
      const sidebarTopics = topics
        .filter((t: any) => t.show_in_sidebar)
        .sort((a: any, b: any) => Number(a.display_number) - Number(b.display_number));
      const grouped = new Map<string, any[]>();
      for (const t of sidebarTopics) {
        const arr = grouped.get(t.nav_section) ?? [];
        arr.push(t); grouped.set(t.nav_section, arr);
      }
      const sections = sectionOrder.filter((s) => grouped.has(s)).concat(
        [...grouped.keys()].filter((s) => !sectionOrder.includes(s))
      );
      let navHtml = '';
      for (const section of sections) {
        navHtml += `<div class="nav-section">${section}</div>`;
        for (const t of grouped.get(section)!) {
          const navLocked = isExpired && !t.topic_content;
          const navLabel =
            section === 'Dynamic Programming' ? stripDpNavSectionNoiseDeep(t.nav_label || '') : t.nav_label;
          navHtml += `<button class="nav-item${navLocked ? ' nav-locked' : ''}" data-topic-id="${t.id}" title="${navLocked ? 'Upgrade to Pro to access this topic' : ''}">`
            + `<span class="num">${t.display_number}</span>${navLabel}`
            + `<span class="tier-dot"><span class="bar"></span><span class="bar"></span><span class="bar"></span></span>`
            + `</button>`;
        }
      }
      document.getElementById('nav-list')!.innerHTML = navHtml;
      document.getElementById('topic-count')!.textContent = `${topics.length} Topics`;

      // ── Build Topic Cards ──

      // Escape HTML special chars for safe text insertion.
      function esc(s: string): string {
        return (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }

      // "Fixed-Window" is sometimes authored with a Unicode hyphen (U+2011, etc.).
      const FIXED_WINDOW_RE = /Fixed[\s\u2010\u2011\u2012\u2013\u2014-]*Window/i;

      // Some topic `summary_meta` strings accidentally repeat the same tag sequence
      // (e.g. "Fixed-Window · Kadane · ... · CHT" showing twice). This removes
      // subsequent occurrences while keeping the first one intact.
      function dedupeLinearDpTagSequence(summaryMeta: string): string {
        if (!summaryMeta) return summaryMeta;

        const sep = '(?:\\s*(?:·|&middot;|&#183;)\\s*)';
        const pattern = `${FIXED_WINDOW_RE.source}${sep}Kadane${sep}Knapsack${sep}LIS${sep}State\\s*Machine${sep}CHT`;
        const re1 = new RegExp(pattern, 'g');

        const first = re1.exec(summaryMeta);
        if (!first || first.index == null) return summaryMeta;

        const firstEnd = first.index + first[0].length;

        const re2 = new RegExp(pattern, 'g');
        const out =
          summaryMeta.slice(0, firstEnd) + summaryMeta.slice(firstEnd).replace(re2, '');

        // Cosmetic: avoid double spaces created by removing the repeated block.
        return out.replace(/[ \t]{2,}/g, ' ');
      }

      // Tag line "Fixed-Window · Kadane · … · CHT" is redundant when the stats line
      // (N problems · stages · …) already lists the same ideas.
      function topicMetaHasProblemStatsLine(s: string): boolean {
        if (!s) return false;
        return (
          /\d+[\s\u00a0]*problems/i.test(s)
          || /fixed-window\s*,\s*knapsack/i.test(s)
        );
      }

      /** Chip row like "A · B · C" (3+ items) — redundant when the next line is "N problems · stages · …". */
      function isMiddotTagLine(s: string): boolean {
        const plain = metaPlainForTags(s);
        const sep = /(?:·|&middot;|&#183;)/;
        const parts = plain.split(sep).map((x) => x.trim()).filter(Boolean);
        return parts.length >= 3;
      }

      /**
       * Dynamic Programming topics: drop a leading middot "tag" block before the first "N problems" line
       * when the stats line already expands the same ideas (avoids duplicate header rows).
       */
      function removeDpRedundantMiddotPrefixBeforeStats(summaryMeta: string): string {
        if (!summaryMeta || !topicMetaHasProblemStatsLine(summaryMeta)) return summaryMeta;

        const problemsIdx = summaryMeta.search(/\d+[\s\u00a0]*problems/i);
        if (problemsIdx <= 0) return summaryMeta;

        const prefix = summaryMeta.slice(0, problemsIdx);
        if (!isMiddotTagLine(prefix)) return summaryMeta;

        const plainLen = metaPlainForTags(prefix).length;
        if (plainLen > 220) return summaryMeta;

        let out = summaryMeta.slice(problemsIdx);
        out = out.replace(/^(?:\s|&nbsp;)*(?:·|&middot;|&#183;)\s*/i, '');
        return out.replace(/[ \t]{2,}/g, ' ').replace(/^\s+|\s+$/g, '');
      }

      // Tag chip row is sometimes stored in `type_label` / `tier_label` while `summary_meta` has the stats row.
      function stripRedundantDpMiddotLabel(label: string, summaryMeta: string): string {
        if (!label || !summaryMeta) return label;
        if (!topicMetaHasProblemStatsLine(summaryMeta)) return label;
        if (!isMiddotTagLine(label)) return label;
        return '';
      }

      const topicMetas: Record<number, string> = {};
      topics.forEach((t: any) => {
        let m = t.topbar_meta || '';
        const isDp = t.nav_section === 'Dynamic Programming';
        if (isDp) {
          m = dedupeLinearDpTagSequence(m);
          if (topicMetaHasProblemStatsLine(m)) {
            m = removeDpRedundantMiddotPrefixBeforeStats(m);
          }
          m = stripDpNavSectionNoiseDeep(m);
        }
        topicMetas[t.id] = m;
      });

      const LAYER_CLS: Record<string, string> = {
        Foundation: 'l1', Variants: 'l2', Combo: 'l3', Hard: 'l4', Trap: 'l5',
      };
      const DIFF_CLS: Record<string, string> = {
        Easy: 'diff-e', Med: 'diff-m', Medium: 'diff-m', Hard: 'diff-h',
      };

      function buildBody(t: any): string {
        const tc = t.topic_content || {};

        // Prefer body_html from topics table — it contains all sections exactly as authored.
        // The problems table exists for structured DB queries; progress tracking
        // still works because body_html retains the original .num-cell elements.
        if (t.body_html) return t.body_html;

        // Fallback: render from structured fields (used before body_html is populated).
        const problems = [...(t.problems || [])].sort(
          (a: any, b: any) => a.order_num - b.order_num
        );
        let h = '';

        if (tc.why_it_matters) {
          h += `<div class="info-box"><strong>Why It Matters:</strong> ${esc(tc.why_it_matters)}</div>`;
        }
        if (tc.core_idea) {
          h += `<div class="core-box"><strong>Core Idea:</strong> ${esc(tc.core_idea)}</div>`;
        }

        if (problems.length) {
          h += `<div class="sec-title">Problem Set</div><div class="tbl-wrap"><table>`;
          h += `<thead><tr><th>#</th><th>Layer</th><th>Link</th><th>Problem</th><th>Diff</th><th>P</th><th>Sub-Variant</th><th>Key Insight</th></tr></thead><tbody>`;
          problems.forEach((p: any) => {
            const isTrap = p.layer === 'Trap';
            const lc = LAYER_CLS[p.layer] || 'l1';
            const link = p.lc_url
              ? `<a class="lc-link" href="${p.lc_url}" target="_blank">LC ${p.lc_number}</a>`
              : '';
            const diff = p.difficulty
              ? `<span class="${DIFF_CLS[p.difficulty] || ''}">${p.difficulty}</span>`
              : '';
            const prem = p.is_premium ? `<span class="prem">✅</span>` : '';
            h += `<tr data-problem-id="${p.id}">`;
            h += `<td class="num-cell">${p.order_num}</td>`;
            h += `<td><span class="${lc}">${isTrap ? '⚠️Trap' : esc(p.layer)}</span></td>`;
            h += `<td>${link}</td>`;
            h += `<td class="prob-name${isTrap ? ' trap-name' : ''}">${isTrap ? '⚠️ ' : ''}${esc(p.title)}</td>`;
            h += `<td>${diff}</td>`;
            h += `<td>${prem}</td>`;
            h += `<td class="variant-cell">${esc(p.sub_variant || '')}</td>`;
            h += `<td class="insight">${esc(p.key_insight || '')}</td>`;
            h += `</tr>`;
          });
          h += `</tbody></table></div>`;
        }

        const triggers: any[] = tc.pattern_triggers || [];
        if (triggers.length) {
          h += `<div class="sec-title">Pattern Triggers</div><div class="tbl-wrap"><table>`;
          h += `<thead><tr><th>Trigger Phrase</th><th>Sub-Variant</th><th>When It BREAKS</th></tr></thead><tbody>`;
          triggers.forEach((tr: any) => {
            h += `<tr>`;
            h += `<td class="trigger-phrase">${esc(tr.trigger)}</td>`;
            h += `<td class="trigger-variant">${esc(tr.sub_variant)}</td>`;
            h += `<td class="trigger-breaks">${esc(tr.breaks_when)}</td>`;
            h += `</tr>`;
          });
          h += `</tbody></table></div>`;
        }

        const cov: string[] = tc.coverage_problems || [];
        if (cov.length) {
          h += `<div class="sec-title">80% Coverage Set</div>`;
          h += `<div class="coverage-box"><strong>Minimum ${cov.length} problems:</strong> `;
          cov.forEach((lc: string) => { h += `<span class="pill">${esc(lc)}</span>`; });
          h += `</div>`;
        }

        const flags: string[] = tc.red_flags || [];
        if (flags.length) {
          h += `<div class="sec-title">Red Flags</div>`;
          flags.forEach((f: string) => { h += `<div class="warn-box">${f}</div>`; });
        }

        return h;
      }

      let cardsHtml = '';
      for (const t of topics as any[]) {
        // topic_content is null when DB RLS blocked it — expired user on a non-free topic
        const isLocked = !t.topic_content;

        let bodyHtml: string;
        if (isLocked) {
          bodyHtml = `<div class="locked-body">
            <div class="locked-icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="white"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zM15.1 8H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/></svg>
            </div>
            <div class="locked-msg">Your free trial has ended</div>
            <div class="locked-sub">Upgrade to unlock all 43 topics and 1150+ problems — includes ${t.title} and everything beyond.</div>
            <div class="locked-price-options">
              <div><span class="locked-price-amt">₹149</span><span class="locked-price-period">/ month</span></div>
              <div><span class="locked-price-amt">₹299</span><span class="locked-price-period">/ 3 months</span></div>
            </div>
            <div class="upgrade-btn-row">
              <button type="button" class="upgrade-btn-card" data-pay-plan="monthly">🔓 Monthly — ₹149</button>
              <button type="button" class="upgrade-btn-card upgrade-btn-card--secondary" data-pay-plan="quarterly">🔓 Quarterly — ₹299</button>
            </div>
          </div>`;
        } else {
          {
            const tc0 = t.topic_content || {};
            bodyHtml =
              t.problems?.length ||
              tc0.why_it_matters ||
              tc0.core_idea ||
              tc0.pattern_triggers?.length ||
              tc0.coverage_problems?.length ||
              tc0.red_flags?.length
                ? buildBody(t)
                : t.body_html || '';
          }
        }

        const isDpTopic = t.nav_section === 'Dynamic Programming';
        let meta = t.summary_meta || '';
        if (isDpTopic) {
          meta = dedupeLinearDpTagSequence(meta);
          if (topicMetaHasProblemStatsLine(meta)) {
            meta = removeDpRedundantMiddotPrefixBeforeStats(meta);
          }
          meta = stripDpNavSectionNoiseDeep(meta);
        }
        const rawSummary = t.summary_meta || '';
        const typeLabel = isDpTopic
          ? stripRedundantDpMiddotLabel(stripDpNavSectionNoiseDeep(t.type_label || ''), rawSummary)
          : (t.type_label || '');
        const tierLabelClean = isDpTopic
          ? stripRedundantDpMiddotLabel(stripDpNavSectionNoiseDeep(t.tier_label || ''), rawSummary)
          : (t.tier_label || '');
        const topicTitle =
          isDpTopic
            ? (() => {
                const cleaned = stripDpNavSectionNoiseDeep(t.title || '').trim();
                return cleaned || t.title;
              })()
            : t.title;
        cardsHtml += `<div class="topic-card topic-collapsed${isLocked ? ' topic-locked' : ''}" id="tp${t.id}"><div class="topic-header"><div class="topic-num">${t.display_number}</div><div style="flex:1"><div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap"><div class="topic-title">${topicTitle}</div><span class="tier-badge tier-${t.tier_code}">${tierLabelClean}</span><span class="topic-type">${typeLabel}</span><button type="button" class="topic-details-btn" aria-expanded="false" title="Show details">Details</button></div><div class="topic-meta">${meta}</div></div></div><div class="topic-body">${bodyHtml}</div></div>`;
      }
      document.getElementById('content')!.innerHTML = cardsHtml;

      // ── Topic header collapse (questions-first) ──
      document.querySelectorAll('.topic-card').forEach((card) => {
        const btn = card.querySelector<HTMLButtonElement>('.topic-details-btn');
        if (!btn) return;
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const collapsed = card.classList.toggle('topic-collapsed');
          btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
          btn.textContent = collapsed ? 'Details' : 'Hide';
          btn.title = collapsed ? 'Show details' : 'Hide details';
        });
      });

      // Wire up upgrade buttons inside locked cards
      document.querySelectorAll('.upgrade-btn-card').forEach((btn) => {
        btn.addEventListener('click', () => {
          const p = (btn as HTMLElement).dataset.payPlan === 'quarterly' ? 'quarterly' : 'monthly';
          openRazorpay(p);
        });
      });

      // ── Patch: add num-cell class to problem tables that lack it (DP topics) ──
      document.querySelectorAll('.topic-body table').forEach((table) => {
        if (table.querySelector('.num-cell')) return;
        const headers = Array.from(table.querySelectorAll('thead th')).map(th => (th.textContent || '').toLowerCase().trim());
        // Heuristic: either the header looks like a problem set, OR we see a LeetCode link cell.
        const isProb =
          headers.some(h => h.includes('difficulty') || h === 'diff' || h.includes('# / name') || h === 'problem' || h === '#')
          || Boolean(table.querySelector('a.lc-link'));
        if (!isProb) return;
        table.querySelectorAll('tbody tr').forEach((row) => {
          const td = row.querySelector('td:first-child');
          if (td && /^\d+$/.test(td.textContent?.trim() || '')) td.classList.add('num-cell');
        });
      });

      // ── Key Insight column: body_html tables often omit class="insight" on <td> ──
      document.querySelectorAll('.topic-body table').forEach((table) => {
        const thr = table.querySelector('thead tr');
        if (!thr) return;
        const headers = Array.from(thr.querySelectorAll('th')).map((th) =>
          (th.textContent || '').toLowerCase().trim()
        );
        const insightIdx = headers.findIndex((h) => h.includes('insight'));
        if (insightIdx < 0) return;
        const thInsight = thr.children[insightIdx];
        if (thInsight && thInsight.tagName === 'TH') {
          thInsight.classList.add('th-insight-walkthrough');
        }
        table.querySelectorAll('tbody tr').forEach((tr) => {
          const td = tr.children[insightIdx];
          if (td && td.tagName === 'TD') {
            td.classList.add('insight');
            if ((td.textContent || '').trim()) td.classList.add('insight-clickable');
          }
        });
      });

      // ── Renumber alphanumeric num-cells (A1,B1…) to sequential (1,2,3…) ──
      document.querySelectorAll('.topic-card').forEach((card) => {
        const numCells = card.querySelectorAll('tbody .num-cell');
        let seq = 0;
        numCells.forEach((cell) => {
          const raw = cell.textContent?.trim() || '';
          // Skip cells that are already pure numbers
          if (/^\d+$/.test(raw)) { seq = parseInt(raw); return; }
          // Alphanumeric like A1, B3, C12, T1 → renumber sequentially
          if (/^[A-Za-z]?\d+$/.test(raw)) {
            seq++;
            cell.textContent = String(seq);
          }
        });
      });

      // ── Attach DB problem IDs on problem-set rows (for problem_playback fetch) ──
      function patchProblemRowIdsFromTopics(topicList: any[]) {
        topicList.forEach((t: any) => {
          if (!t.problems?.length) return;
          const card = document.getElementById(`tp${t.id}`);
          if (!card) return;
          const sorted = [...t.problems].sort((a: any, b: any) => a.order_num - b.order_num);
          const tables = card.querySelectorAll('.topic-body table');
          let targetTable: HTMLTableElement | null = null;
          for (const table of tables) {
            const headers = Array.from(table.querySelectorAll('thead th')).map((th) =>
              (th.textContent || '').toLowerCase()
            );
            if (
              headers.some((h) => h.includes('insight'))
              && (headers.some((h) => h.includes('link')) || headers.some((h) => h.includes('layer')))
            ) {
              targetTable = table as HTMLTableElement;
              break;
            }
          }
          if (!targetTable) {
            for (const table of tables) {
              if (table.querySelector('tbody tr .num-cell')) {
                targetTable = table as HTMLTableElement;
                break;
              }
            }
          }
          if (!targetTable) return;
          const rows = [...targetTable.querySelectorAll('tbody tr')].filter((r) => r.querySelector('.num-cell'));
          rows.forEach((row, idx) => {
            const p = sorted[idx];
            if (p?.id != null) row.setAttribute('data-problem-id', String(p.id));
          });
        });
      }
      patchProblemRowIdsFromTopics(topics);

      let w98Active = studyProblemsOnlyPref;

      function syncGuideMethodStripVisibility() {
        const strip = document.getElementById('guide-method-strip');
        if (!strip) return;
        if (sessionStorage.getItem(GUIDE_METHOD_DISMISS_KEY) === '1') {
          strip.hidden = true;
          return;
        }
        strip.hidden = w98Active;
      }
      syncGuideMethodStripVisibility();

      function appendProblemsOnlyToggle(titleRow: HTMLElement) {
        const lab = document.createElement('label');
        lab.className = 'w98-switch w98-switch--inline study-toggle study-toggle--problems' + (isPaid ? '' : ' study-pref--locked');
        lab.title = isPaid
          ? 'Problems only: hide explanations and extra sections (saved to your Pro profile)'
          : 'Pro only — upgrade to filter the guide down to problem tables and sync this preference.';
        lab.innerHTML =
          '<input type="checkbox" class="w98-topic-toggle" /><span class="w98-slider"></span>'
          + '<span class="w98-label">Just problems</span>';
        titleRow.appendChild(lab);
        const inp = lab.querySelector('.w98-topic-toggle') as HTMLInputElement;
        inp.checked = isPaid && w98Active;
        inp.disabled = !isPaid;
      }

      // ── Per-topic Core set + Problems only (Pro: both sync to profile) ──
      document.querySelectorAll('.topic-card').forEach((card) => {
        const titleRow = card.querySelector('.topic-title')?.parentElement as HTMLElement | undefined;
        if (!titleRow) return;
        const topicIdStr = card.id.replace(/^tp/, '');

        const pills = card.querySelectorAll('.coverage-box .pill');
        if (pills.length) {
          const coverageSet = new Set<string>();
          pills.forEach((pill) => {
            const m = (pill.textContent || '').match(/\d+/);
            if (m) coverageSet.add(m[0]);
          });
          if (coverageSet.size) {
            let inMinCount = 0;
            card.querySelectorAll('tbody tr').forEach((row) => {
              if (!row.querySelector('.num-cell')) return;
              const lcLink = row.querySelector('.lc-link');
              const m = (lcLink?.textContent || '').match(/\d+/);
              if (m && coverageSet.has(m[0])) {
                row.classList.add('in-min');
                inMinCount++;
              }
            });
            if (inMinCount) {
              const toggle = document.createElement('label');
              toggle.className = 'min-switch study-toggle study-toggle--core' + (isPaid ? '' : ' study-pref--locked');
              toggle.title = isPaid
                ? `Core set: show only the ${inMinCount} minimum coverage problems (saved per topic in your Pro profile)`
                : `Pro only — upgrade to show only these ${inMinCount} core coverage problems and save per topic.`;
              toggle.innerHTML =
                '<input type="checkbox" class="min-toggle" /><span class="min-slider"></span>'
                + '<span class="min-label">Core bites</span>';
              titleRow.appendChild(toggle);
              const checkbox = toggle.querySelector('.min-toggle') as HTMLInputElement;
              if (isPaid && studyMinByTopic[topicIdStr]) {
                checkbox.checked = true;
                card.classList.add('min-active');
              }
              checkbox.disabled = !isPaid;
              if (isPaid) {
                checkbox.addEventListener('change', () => {
                  card.classList.toggle('min-active', checkbox.checked);
                  if (checkbox.checked) studyMinByTopic[topicIdStr] = true;
                  else delete studyMinByTopic[topicIdStr];
                  schedulePersistStudyPrefs();
                });
              }
            }
          }
        }

        // Some authored tables may not include `.num-cell` even after patching; `.lc-link` is a strong signal
        // that this topic has a problem set, so we can still show the filter UI.
        if (card.querySelector('.lc-link')) {
          const revToggle = document.createElement('label');
          revToggle.className = 'rev-switch study-toggle study-toggle--rev' + (isPaid ? '' : ' study-pref--locked');
          revToggle.title = isPaid
            ? 'Revision only: hide everything except the problem table, and show only rows marked for revision (saved per topic in your Pro profile)'
            : 'Pro only — upgrade to filter by revision marks and save per topic.';
          revToggle.innerHTML =
            '<input type="checkbox" class="rev-only-toggle" /><span class="rev-slider"></span>'
            + '<span class="rev-label">Redo queue</span>';
          titleRow.appendChild(revToggle);
          const revCb = revToggle.querySelector('.rev-only-toggle') as HTMLInputElement;
          if (isPaid && studyRevOnlyByTopic[topicIdStr]) {
            revCb.checked = true;
            card.classList.add('rev-only-active');
          }
          revCb.disabled = !isPaid;
          if (isPaid) {
            revCb.addEventListener('change', () => {
              card.classList.toggle('rev-only-active', revCb.checked);
              if (revCb.checked) studyRevOnlyByTopic[topicIdStr] = true;
              else delete studyRevOnlyByTopic[topicIdStr];
              schedulePersistStudyPrefs();
              applyW98();
            });
          }
        }

        appendProblemsOnlyToggle(titleRow);
      });

      // ── Progress Tracking (checkboxes always visible; Pro syncs to server) ──
      const userId = session.user.id;
      let completedSet = new Set<string>();
      let revisionSet = new Set<string>();
      let dailySolvedMap: Record<string, number> = {};
      if (isPaid) {
        const { data: progress } = await supabase.from('user_progress').select('topic_id, problem_num').eq('user_id', userId);
        completedSet = new Set((progress || []).map((p: any) => `${p.topic_id}-${p.problem_num}`));
        const { data: revRows } = await supabase.from('user_revision').select('topic_id, problem_num').eq('user_id', userId);
        revisionSet = new Set((revRows || []).map((r: any) => `${r.topic_id}-${r.problem_num}`));
      }

      // ── Daily solved heatmap (GitHub-style) ──
      const streakCard = document.getElementById('daily-streak-card') as HTMLElement | null;
      const streakRow = document.getElementById('daily-streak-row') as HTMLElement | null;
      const streakMeta = document.getElementById('daily-streak-meta') as HTMLButtonElement | null;
      const heatmapGrid = document.getElementById('daily-heatmap-grid') as HTMLElement | null;
      const heatmapMeta = document.getElementById('daily-heatmap-meta') as HTMLElement | null;
      const streakOpenYear = document.getElementById('streak-open-year') as HTMLButtonElement | null;
      const heatmapModal = document.getElementById('heatmap-modal') as HTMLElement | null;
      const heatmapModalClose = document.getElementById('heatmap-modal-close') as HTMLButtonElement | null;
      const heatmapMonths = document.getElementById('daily-heatmap-months') as HTMLElement | null;
      const heatmapModalSubtitle = document.getElementById('heatmap-modal-subtitle') as HTMLElement | null;

      function ymd(d: Date) {
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${y}-${m}-${day}`;
      }
      function startOfDay(d: Date) {
        return new Date(d.getFullYear(), d.getMonth(), d.getDate());
      }
      function addDays(d: Date, n: number) {
        const x = new Date(d);
        x.setDate(x.getDate() + n);
        return x;
      }
      function addMonths(d: Date, n: number) {
        const x = new Date(d);
        x.setMonth(x.getMonth() + n);
        return x;
      }
      function isoWeekdayMon0(d: Date) {
        // JS: 0=Sun..6=Sat → map to 0=Mon..6=Sun
        return (d.getDay() + 6) % 7;
      }
      function levelForCount(n: number) {
        if (!n || n <= 0) return 0;
        if (n === 1) return 1;
        if (n <= 3) return 2;
        if (n <= 6) return 3;
        return 4;
      }
      function sumLastNDays(map: Record<string, number>, days: number) {
        const today = startOfDay(new Date());
        let total = 0;
        for (let i = 0; i < days; i++) {
          const k = ymd(addDays(today, -i));
          total += map[k] || 0;
        }
        return total;
      }

      function renderHeatmap(map: Record<string, number>, rangeStart: Date) {
        if (!isPaid || !heatmapGrid || !heatmapMeta) return;
        heatmapGrid.innerHTML = '';
        if (heatmapMonths) heatmapMonths.innerHTML = '';

        const today = startOfDay(new Date());
        const end = today;
        const start = startOfDay(rangeStart);
        // Align grid to Monday start (GitHub-like columns)
        const gridStart = addDays(start, -isoWeekdayMon0(start));
        const gridEnd = addDays(end, (6 - isoWeekdayMon0(end)));
        const totalDays = Math.round((gridEnd.getTime() - gridStart.getTime()) / 86400000) + 1;
        const weeks = Math.ceil(totalDays / 7);

        const rangeSubtitleFmt = new Intl.DateTimeFormat(undefined, {
          month: 'short',
          day: 'numeric',
          year: 'numeric',
        });
        if (heatmapModalSubtitle) {
          heatmapModalSubtitle.textContent = `${rangeSubtitleFmt.format(start)} – ${rangeSubtitleFmt.format(end)}`;
        }

        heatmapGrid.style.setProperty('--heatmap-weeks', String(weeks));
        if (heatmapMonths) heatmapMonths.style.setProperty('--heatmap-weeks', String(weeks));

        let bestDay = { key: '', count: 0 };
        let total = 0;

        // Month labels aligned to week columns
        if (heatmapMonths) {
          const monthFmt = new Intl.DateTimeFormat(undefined, { month: 'short' });
          const yearFmt = new Intl.DateTimeFormat(undefined, { year: 'numeric' });
          const labels: Array<string | null> = Array.from({ length: weeks }, () => null);

          const monthYear = (d: Date) => `${monthFmt.format(d)}\n${yearFmt.format(d)}`;
          // First column: month + year for the range start (stacked, fits narrow cols)
          labels[0] = monthYear(start);
          // Each 1st of month: month + year
          for (let i = 0; i < totalDays; i++) {
            const d = addDays(gridStart, i);
            if (d.getDate() !== 1) continue;
            const weekIdx = Math.floor(i / 7);
            if (weekIdx < 0 || weekIdx >= weeks) continue;
            labels[weekIdx] = monthYear(d);
          }
          // Render as a grid with week columns
          heatmapMonths.classList.toggle('heatmap-months--two-year', start.getFullYear() !== end.getFullYear());
          heatmapMonths.innerHTML = labels
            .map((t) => `<span class="heatmap-month">${t ? t : ''}</span>`)
            .join('');
        }

        for (let i = 0; i < totalDays; i++) {
          const d = addDays(gridStart, i);
          const key = ymd(d);
          const count = map[key] || 0;
          total += count;
          if (count > bestDay.count) bestDay = { key, count };
          const lv = levelForCount(count);
          const cell = document.createElement('button');
          cell.type = 'button';
          cell.className = `heatmap-cell heatmap-l${lv}`;
          cell.setAttribute('role', 'gridcell');
          cell.setAttribute('data-day', key);
          cell.textContent = String(d.getDate());
          cell.title = `${key}: ${count} solved`;
          cell.setAttribute('aria-label', `${key}: ${count} solved`);
          cell.addEventListener('click', async () => {
            if (!isPaid) return openRazorpay('monthly');
            // Heatmap is DB-derived; update it by solving problems (checkboxes).
          });
          heatmapGrid.appendChild(cell);
        }

        const last7 = sumLastNDays(map, 7);
        const last30 = sumLastNDays(map, 30);
        const todayCount = map[ymd(today)] || 0;
        heatmapMeta.textContent =
          `Today: ${todayCount} · Last 7 days: ${last7} · Last 30 days: ${last30}` +
          (bestDay.count > 0 ? ` · Best: ${bestDay.count} on ${bestDay.key}` : '');
      }

      /** e.g. May 2–8, 2026 (no “May 02” padding); spans months/years when needed */
      function streakRangeLabel(a: Date, b: Date) {
        const mo = new Intl.DateTimeFormat(undefined, { month: 'short' });
        const dayNum = new Intl.DateTimeFormat(undefined, { day: 'numeric' });
        const yearNum = new Intl.DateTimeFormat(undefined, { year: 'numeric' });
        const sameMonth = a.getMonth() === b.getMonth() && a.getFullYear() === b.getFullYear();
        const sameYear = a.getFullYear() === b.getFullYear();
        if (sameMonth) {
          return `${mo.format(a)} ${dayNum.format(a)}–${dayNum.format(b)}, ${yearNum.format(b)}`;
        }
        if (sameYear) {
          return `${mo.format(a)} ${dayNum.format(a)} – ${mo.format(b)} ${dayNum.format(b)}, ${yearNum.format(b)}`;
        }
        return `${mo.format(a)} ${dayNum.format(a)}, ${yearNum.format(a)} – ${mo.format(b)} ${dayNum.format(b)}, ${yearNum.format(b)}`;
      }

      function renderStreak(map: Record<string, number>) {
        if (!isPaid || !streakCard || !streakRow || !streakMeta) return;
        streakRow.innerHTML = '';
        const today = startOfDay(new Date());
        const fmtCell = new Intl.DateTimeFormat(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
        const dowFmt = new Intl.DateTimeFormat(undefined, { weekday: 'short' });
        let streak = 0;
        for (let i = 0; i < 365; i++) {
          const k = ymd(addDays(today, -i));
          const c = map[k] || 0;
          if (c > 0) streak++;
          else break;
        }
        const last7 = sumLastNDays(map, 7);
        const first = addDays(today, -6);
        const range = streakRangeLabel(first, today);
        streakMeta.textContent = range;
        streakMeta.title = `${streak} day streak · ${last7} solved in last 7 days (click to refresh)`;
        streakMeta.setAttribute('aria-label', `${range}. ${streak} day streak, ${last7} solved in last 7 days`);

        for (let i = 6; i >= 0; i--) {
          const d = addDays(today, -i);
          const k = ymd(d);
          const c = map[k] || 0;
          const lv = levelForCount(c);
          const cell = document.createElement('button');
          cell.type = 'button';
          const dow = dowFmt.format(d);
          const dowLetter = (dow || '').trim().slice(0, 1).toUpperCase() || '';
          cell.className = `streak-cell heatmap-l${lv}` + (i === 0 ? ' streak-cell--today' : '');
          cell.title = `${fmtCell.format(d)} (${k}): ${c} solved`;
          cell.setAttribute('aria-label', `${k}: ${c} solved`);
          cell.setAttribute('data-dow', dowLetter);
          cell.textContent = String(d.getDate());
          cell.addEventListener('click', () => {
            if (!isPaid) return openRazorpay('monthly');
            openYearView();
          });
          streakRow.appendChild(cell);
        }
        streakCard.hidden = false;
      }

      function openYearView() {
        if (!isPaid || !heatmapModal) return;
        heatmapModal.hidden = false;
        heatmapModal.classList.add('open');
      }
      function closeYearView() {
        if (!heatmapModal) return;
        heatmapModal.classList.remove('open');
        heatmapModal.hidden = true;
      }

      async function fetchDailySolved() {
        if (!isPaid) return;
        const today = startOfDay(new Date());
        const createdAt = startOfDay(new Date((session.user as any).created_at || Date.now()));
        const sixMonthsBack = startOfDay(addMonths(today, -6));
        const rangeStartDate = createdAt > sixMonthsBack ? createdAt : sixMonthsBack;
        const start = ymd(rangeStartDate);
        const end = ymd(today);
        const { data, error } = await supabase
          .from('user_daily_solved_view')
          .select('day, solved_count')
          .eq('user_id', userId)
          .gte('day', start)
          .lte('day', end);
        if (error) return;
        dailySolvedMap = {};
        (data || []).forEach((r: any) => {
          const k = typeof r.day === 'string' ? r.day : String(r.day);
          dailySolvedMap[k] = Number(r.solved_count || 0);
        });
        renderStreak(dailySolvedMap);
        renderHeatmap(dailySolvedMap, rangeStartDate);
      }

      if (streakMeta) {
        streakMeta.addEventListener('click', async () => {
          if (!isPaid) return openRazorpay('monthly');
          await fetchDailySolved();
        });
      }
      if (streakOpenYear) {
        streakOpenYear.addEventListener('click', () => {
          if (!isPaid) return openRazorpay('monthly');
          openYearView();
        });
      }
      if (heatmapModalClose) {
        heatmapModalClose.addEventListener('click', closeYearView);
      }
      if (heatmapModal) {
        heatmapModal.addEventListener('click', (e) => {
          if (e.target === heatmapModal) closeYearView();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeYearView();
        });
      }

      if (isPaid) {
        // Don’t block the rest of the UI; render when ready.
        fetchDailySolved();
      } else {
        if (streakCard) {
          streakCard.hidden = true;
          streakCard.classList.remove('streak-card--locked');
        }
        closeYearView();
      }
      const REV_PIN_SVG =
        '<svg width="11" height="12" viewBox="0 0 11 12" aria-hidden="true"><path class="rev-pin-shape" d="M1.75 1.25h7.5v9.35L5.5 8.05 1.75 10.6V1.25z" fill="none" stroke="currentColor" stroke-width="1.05" stroke-linejoin="round"/></svg>';
      document.querySelectorAll('.topic-card').forEach((card) => {
        const topicId = parseInt(card.id.replace('tp', ''));
        card.querySelectorAll('tbody tr').forEach((row) => {
          const numCell = row.querySelector('.num-cell');
          if (!numCell) return;
          const probNum = parseInt(numCell.textContent?.trim() || '0');
          if (!probNum) return;
          const key = `${topicId}-${probNum}`;
          const isComplete = isPaid && completedSet.has(key);
          const isRevision = isPaid && revisionSet.has(key);
          const cb = document.createElement('input');
          cb.type = 'checkbox';
          cb.checked = isComplete;
          cb.className = 'progress-cb' + (isPaid ? '' : ' progress-cb--locked');
          cb.disabled = !isPaid;
          if (isPaid) {
            cb.title = isComplete ? 'Mark incomplete' : 'Mark complete';
            cb.setAttribute('aria-label', cb.title);
          } else {
            const lockedHint = 'Pro only — upgrade to mark problems solved and sync progress.';
            cb.title = lockedHint;
            cb.setAttribute('aria-label', lockedHint);
          }
          if (isComplete) row.classList.add('row-done');
          if (isRevision) row.classList.add('row-revision');
          // Keep # column perfectly aligned: fixed-width controls + stable number text
          const numRaw = (numCell.textContent || '').trim();
          const inner = document.createElement('span');
          inner.className = 'num-cell-inner';

          const controls = document.createElement('span');
          controls.className = 'num-controls';
          controls.appendChild(cb);

          const numText = document.createElement('span');
          numText.className = 'num-text';
          numText.textContent = numRaw;

          const revBtn = document.createElement('button');
          revBtn.type = 'button';
          revBtn.className = 'rev-pin';
          revBtn.innerHTML = REV_PIN_SVG;
          revBtn.setAttribute('aria-pressed', isRevision ? 'true' : 'false');
          if (isPaid) {
            revBtn.title = isRevision ? 'Remove from revision' : 'Mark for revision';
            revBtn.setAttribute('aria-label', revBtn.title);
          } else {
            const revLocked = 'Pro only — upgrade to save revision marks across devices.';
            revBtn.title = revLocked;
            revBtn.setAttribute('aria-label', revLocked);
            revBtn.disabled = true;
          }
          controls.appendChild(revBtn);

          // Replace existing content with a stable inline layout.
          numCell.textContent = '';
          inner.appendChild(controls);
          inner.appendChild(numText);
          numCell.appendChild(inner);

          if (isPaid) {
            cb.addEventListener('change', async () => {
              cb.disabled = true;
              if (cb.checked) {
                const { error } = await supabase.from('user_progress').insert({ user_id: userId, topic_id: topicId, problem_num: probNum });
                if (error) { cb.checked = false; } else { row.classList.add('row-done'); completedSet.add(key); fetchDailySolved(); }
              } else {
                const { error } = await supabase.from('user_progress').delete().eq('user_id', userId).eq('topic_id', topicId).eq('problem_num', probNum);
                if (error) { cb.checked = true; } else { row.classList.remove('row-done'); completedSet.delete(key); fetchDailySolved(); }
              }
              cb.disabled = false;
              cb.title = cb.checked ? 'Mark incomplete' : 'Mark complete';
              cb.setAttribute('aria-label', cb.title);
            });
            revBtn.addEventListener('click', async (e) => {
              e.preventDefault();
              e.stopPropagation();
              revBtn.disabled = true;
              const wasOn = revisionSet.has(key);
              if (wasOn) {
                const { error } = await supabase
                  .from('user_revision')
                  .delete()
                  .eq('user_id', userId)
                  .eq('topic_id', topicId)
                  .eq('problem_num', probNum);
                if (!error) {
                  revisionSet.delete(key);
                  row.classList.remove('row-revision');
                  revBtn.setAttribute('aria-pressed', 'false');
                  revBtn.title = 'Mark for revision';
                  revBtn.setAttribute('aria-label', revBtn.title);
                }
              } else {
                const { error } = await supabase.from('user_revision').insert({ user_id: userId, topic_id: topicId, problem_num: probNum });
                if (!error) {
                  revisionSet.add(key);
                  row.classList.add('row-revision');
                  revBtn.setAttribute('aria-pressed', 'true');
                  revBtn.title = 'Remove from revision';
                  revBtn.setAttribute('aria-label', revBtn.title);
                }
              }
              revBtn.disabled = false;
            });
          }
        });
      });

      // ── Sidebar Progress Indicators ──
      function updateSidebarProgress() {
        document.querySelectorAll('.nav-item').forEach((navItem) => {
          const topicId = parseInt(navItem.getAttribute('data-topic-id')!);
          const card = document.getElementById(`tp${topicId}`);
          if (!card) return;
          const totalRows = card.querySelectorAll('tbody tr .num-cell').length;
          if (!totalRows) return;
          let doneCount = 0;
          card.querySelectorAll('tbody tr').forEach((row) => {
            if (row.classList.contains('row-done')) doneCount++;
          });
          const indicator = navItem.querySelector('.tier-dot') as HTMLElement;
          if (!indicator) return;
          const bars = indicator.querySelectorAll('.bar') as NodeListOf<HTMLElement>;
          const ratio = doneCount / totalRows;
          let color: string;
          let glow: string;
          let label: string;
          if (doneCount === 0) {
            color = 'var(--divider)'; glow = 'none'; label = 'Not started';
          } else if (doneCount === totalRows) {
            color = '#22c55e'; glow = '0 0 4px rgba(34,197,94,0.5)'; label = `Completed (${doneCount}/${totalRows})`;
          } else {
            color = '#f59e0b'; glow = '0 0 4px rgba(245,158,11,0.4)'; label = `In progress (${doneCount}/${totalRows})`;
          }
          // Light up bars based on progress ratio
          const litBars = doneCount === 0 ? 0 : doneCount === totalRows ? 3 : ratio > 0.5 ? 2 : 1;
          bars.forEach((bar, i) => {
            if (i < litBars) {
              bar.style.background = color;
              bar.style.boxShadow = glow;
            } else {
              bar.style.background = 'var(--divider)';
              bar.style.boxShadow = 'none';
            }
          });
          indicator.title = label;
        });
      }
      // ── Overall Progress Bar ──
      function updateOverallProgress() {
        const fill = document.getElementById('overall-fill') as HTMLElement | null;
        const text = document.getElementById('overall-text');
        if (!fill || !text) return;
        const allRows = document.querySelectorAll('tbody tr .num-cell').length;
        const doneRows = document.querySelectorAll('tbody tr.row-done').length;
        const pct = allRows ? Math.round((doneRows / allRows) * 100) : 0;
        fill.style.width = `${pct}%`;
        text.textContent = `${doneRows}/${allRows} solved (${pct}%)`;
      }

      updateSidebarProgress();
      if (isPaid) {
        updateOverallProgress();
        document.querySelectorAll('.progress-cb:not(:disabled)').forEach((cb) => {
          cb.addEventListener('change', () => setTimeout(() => { updateSidebarProgress(); updateOverallProgress(); }, 100));
        });
      } else {
        const op = document.getElementById('overall-progress')!;
        op.innerHTML = '<div class="overall-progress-bar" style="opacity:0.3"><div class="overall-progress-fill" style="width:35%"></div></div><span style="font-size:0.65rem;color:var(--muted);display:flex;align-items:center;justify-content:center;gap:0.3rem;margin-top:0.2rem;cursor:pointer;" id="pro-progress-cta">&#128274; Pro: Track progress</span>';
        document.getElementById('pro-progress-cta')!.addEventListener('click', () => openRazorpay('monthly'));
        // Non-pro: dim progress dots (no lock icon — same tier-dot affordance as Pro)
        document.querySelectorAll('.nav-item .tier-dot').forEach((dot) => {
          const el = dot as HTMLElement;
          el.style.opacity = '0.25';
          el.title = 'Upgrade to Pro to track progress';
        });
      }

      // ── Show page ──
      document.querySelector('.app')!.removeAttribute('style');

      // ── Theme Toggle ──
      function toggleTheme() {
        const cur = document.documentElement.getAttribute('data-theme');
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch (e) {}
      }
      document.querySelectorAll('.theme-btn, #theme-toggle-top').forEach((btn) => {
        btn.addEventListener('click', toggleTheme);
      });

      // ── Problems only (global) + Revision only (per topic): strip non–problem-set sections ──
      function applyTopicBodyVisibility() {
        document.querySelectorAll('.topic-body').forEach((body) => {
          const card = body.closest('.topic-card');
          const revOnlyThisTopic = Boolean(card?.classList.contains('rev-only-active'));
          const wantProblemFocus = w98Active || revOnlyThisTopic;
          Array.from(body.children).forEach((child) => {
            const el = child as HTMLElement;
            const tbl = el.tagName === 'TABLE' ? el : el.querySelector('table');
            const isProblemTable = tbl && tbl.querySelector('.num-cell');
            const txt = el.textContent || '';
            const isProblemHeading = (el.classList.contains('sec-title') || /^H[1-6]$/.test(el.tagName))
              && (/problem\s*set/i.test(txt) || /section\s*[A-Z]/i.test(txt));
            if (wantProblemFocus) {
              if (isProblemTable || isProblemHeading) {
                el.style.setProperty('display', isProblemTable ? 'block' : '', 'important');
              } else {
                el.style.setProperty('display', 'none', 'important');
              }
            } else {
              el.style.removeProperty('display');
            }
          });
        });
      }
      function applyW98() {
        document.documentElement.classList.toggle('w98-mode', w98Active);
        applyTopicBodyVisibility();
        syncGuideMethodStripVisibility();
      }
      function syncW98TopicToggles() {
        document.querySelectorAll('.w98-topic-toggle').forEach((el) => {
          const inp = el as HTMLInputElement;
          if (!inp.disabled) inp.checked = w98Active;
        });
      }
      syncW98TopicToggles();
      applyW98();
      if (isPaid) {
        document.querySelectorAll('.w98-topic-toggle').forEach((el) => {
          el.addEventListener('change', () => {
            w98Active = (el as HTMLInputElement).checked;
            syncW98TopicToggles();
            applyW98();
            schedulePersistStudyPrefs();
          });
        });
      }

      // ── Topic Switching ──
      const navItems = document.querySelectorAll('.nav-item');
      const topicCards = document.querySelectorAll('.topic-card');
      const topbarTitle = document.getElementById('topbar-title')!;
      const topbarMeta = document.getElementById('topbar-meta')!;

      function show(topicNum: number, clickedItem: Element) {
        navItems.forEach((item) => item.classList.remove('active'));
        clickedItem.classList.add('active');
        topicCards.forEach((card) => card.classList.remove('active'));
        const activeCard = document.getElementById(`tp${topicNum}`);
        if (activeCard) activeCard.classList.add('active');
        // Avoid duplicating the topic title (it already appears in the topic card header).
        // Topbar shows only higher-level context.
        topbarTitle.textContent = topicMetas[topicNum] || '';
        topbarMeta.textContent = '';
        const sb = document.getElementById('sidebar')!;
        if (sb.classList.contains('open')) sb.classList.remove('open');
        try { localStorage.setItem('lastTopic', String(topicNum)); } catch (e) {}

        // Jump user directly to the questions table (first problem set) to reduce bloat.
        if (activeCard) {
          // Avoid `:has()` for broader browser support.
          const tables = Array.from(activeCard.querySelectorAll('.topic-body table')) as HTMLElement[];
          const target =
            (tables.find((t) => Boolean(t.querySelector('.num-cell'))) as HTMLElement | undefined)
            || (activeCard.querySelector('.topic-body a.lc-link')?.closest('table') as HTMLElement | null)
            || (tables[0] as HTMLElement | undefined)
            || null;
          if (target) {
            // scrollIntoView + adjust for sticky topbar
            setTimeout(() => {
              // Avoid non-standard behavior values ("instant") which can throw in some browsers.
              target.scrollIntoView({ block: 'start', behavior: 'auto' });
              const tb = document.querySelector('.topbar') as HTMLElement | null;
              const tbH = tb ? tb.getBoundingClientRect().height : 0;
              window.scrollBy(0, -Math.round(tbH + 10));
            }, 0);
          }
        }
      }

      navItems.forEach((item) => {
        item.addEventListener('click', () => {
          show(parseInt(item.getAttribute('data-topic-id')!), item);
        });
      });

      // ── Remember Last Topic ──
      const lastTopic = localStorage.getItem('lastTopic');
      if (lastTopic) {
        const lastNav = document.querySelector(`.nav-item[data-topic-id="${lastTopic}"]`);
        if (lastNav) show(parseInt(lastTopic), lastNav);
      }


      // ── Key Insight Step-by-Step Overlay ──
      (function () {
        const overlay    = document.getElementById('insight-overlay')!;
        const badge      = overlay.querySelector('.insight-lc-badge')!;
        const titleEl    = overlay.querySelector('.insight-title')!;

        // Views
        const vizView    = overlay.querySelector<HTMLElement>('.viz-view')!;
        const vizLabel   = overlay.querySelector<HTMLElement>('.viz-step-label')!;
        const vizWrap    = overlay.querySelector<HTMLElement>('.viz-frame-wrap')!;
        const vizNote    = overlay.querySelector<HTMLElement>('.viz-frame-note')!;
        const solView    = overlay.querySelector<HTMLElement>('.sol-view')!;
        const insightChipTime  = overlay.querySelector<HTMLElement>('.insight-chip-time')!;
        const insightChipSpace = overlay.querySelector<HTMLElement>('.insight-chip-space')!;
        const stepTitle     = overlay.querySelector('.sol-step-title')!;
        const solWordCodeEl = overlay.querySelector<HTMLElement>('.sol-word-code')!;
        const solExplainEl  = overlay.querySelector<HTMLElement>('.sol-explain')!;
        const codeEl        = overlay.querySelector<HTMLElement>('.sol-code')!;
        const noteEl        = overlay.querySelector<HTMLElement>('.sol-note')!;
        const solSplitEl    = overlay.querySelector<HTMLElement>('.sol-split')!;
        const solDryAside   = overlay.querySelector<HTMLElement>('.sol-split-dry')!;
        const solDryCaption = overlay.querySelector<HTMLElement>('.sol-dry-caption')!;
        const solDryFrame   = overlay.querySelector<HTMLElement>('.sol-dry-frame')!;
        const solDryAux     = overlay.querySelector<HTMLElement>('.sol-dry-aux')!;
        const fallback   = overlay.querySelector<HTMLElement>('.insight-steps')!;
        const insightPanel = overlay.querySelector<HTMLElement>('.insight-panel')!;

        // Shared controls
        const controls   = overlay.querySelector<HTMLElement>('.overlay-controls')!;
        const dotsEl     = overlay.querySelector('.sol-dots')!;
        const prevBtn    = overlay.querySelector<HTMLButtonElement>('.sol-prev')!;
        const ppBtn      = overlay.querySelector<HTMLButtonElement>('.sol-playpause')!;
        const nextBtn    = overlay.querySelector<HTMLButtonElement>('.sol-next')!;
        const counter    = overlay.querySelector('.sol-counter')!;
        const speedSelect = document.getElementById('insight-speed') as HTMLSelectElement;
        const LS_PLAYBACK_SPEED = 'insightPlaybackSpeed';
        const SPEED_CHOICES = [0.5, 1, 1.5, 2, 3] as const;

        // ── State ──
        type OverlayMode = 'viz' | 'sol' | 'both';
        let mode: OverlayMode = 'sol';
        /** Viz frames when mode === 'both' (solution steps drive the timeline). */
        let vizFrameList: any[] = [];
        let frames: any[] = [];
        let currentStep = 0;
        let isPlaying = false;
        let twTimer = 0;
        let advTimer = 0;
        /** Slightly slower typing/dwell only for very long curated walks */
        let playbackExpanded = false;
        /** Any step in current solution carries a dry-run snapshot */
        let solutionHasAnyDry = false;
        /** 0.5 … 3 — higher = faster (viz advance, typewriter, dwell) */
        let playbackSpeed = 1;

        function nearestPlaybackSpeed(v: number): number {
          let best = SPEED_CHOICES[1];
          let bestD = Infinity;
          for (const s of SPEED_CHOICES) {
            const d = Math.abs(s - v);
            if (d < bestD) {
              bestD = d;
              best = s;
            }
          }
          return best;
        }

        try {
          const saved = parseFloat(localStorage.getItem(LS_PLAYBACK_SPEED) || '1');
          if (Number.isFinite(saved) && saved >= 0.5 && saved <= 3) {
            playbackSpeed = nearestPlaybackSpeed(saved);
          }
        } catch (_) {
          /* ignore */
        }

        function syncSpeedSelect() {
          const v = String(playbackSpeed);
          if ([...speedSelect.options].some((o) => o.value === v)) speedSelect.value = v;
          else {
            speedSelect.value = '1';
            playbackSpeed = 1;
          }
        }

        /** Shorter CSS transitions when playback is faster (1/speed). */
        function applyPlaybackSpeedCss() {
          overlay.style.setProperty('--insight-speed-visual', String(1 / playbackSpeed));
        }

        syncSpeedSelect();
        applyPlaybackSpeedCss();

        /**
         * Scale durations: 2× speed → half the wait.
         * Use a low `floorMs` for per-character typing; higher floor for gaps between steps
         * so timers never fire too eagerly.
         */
        function atSpeed(ms: number, floorMs = 40): number {
          return Math.max(floorMs, Math.round(ms / playbackSpeed));
        }

        speedSelect.addEventListener('change', () => {
          const v = parseFloat(speedSelect.value);
          if (v >= 0.5 && v <= 3) playbackSpeed = v;
          try {
            localStorage.setItem(LS_PLAYBACK_SPEED, String(playbackSpeed));
          } catch (_) {
            /* ignore */
          }
          applyPlaybackSpeedCss();
          if (overlay.classList.contains('active') && isPlaying) {
            stopAll();
            showFrame(currentStep);
          }
        });

        function stepHasDrySnapshot(dry: unknown): boolean {
          if (!dry || typeof dry !== 'object') return false;
          const d = dry as { cells?: unknown[]; auxLines?: unknown[] };
          return Boolean((d.cells && d.cells.length > 0) || (d.auxLines && d.auxLines.length > 0));
        }

        function escHtml(s: string) {
          return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        function setInsightChips(time: string, space: string) {
          insightChipTime.textContent = time || '—';
          insightChipSpace.textContent = space || '—';
        }

        /** Merge LC / keyword / prose fallbacks into chips (and sol when present). */
        function applyResolvedComplexity(
          lc: string,
          tit: string,
          ins: string,
          s: { time?: string; space?: string } | null
        ) {
          const cx = resolvePlaybackComplexity(lc, tit, ins, s);
          if (s && typeof s === 'object') {
            s.time = cx.time;
            s.space = cx.space;
          }
          setInsightChips(cx.time, cx.space);
        }

        function stopAll() { clearInterval(twTimer); clearTimeout(advTimer); }

        function syncControls() {
          dotsEl.querySelectorAll('.sol-dot').forEach((d, i) =>
            d.classList.toggle('active', i === currentStep)
          );
          counter.textContent = `${currentStep + 1} / ${frames.length}`;
          prevBtn.disabled = currentStep === 0;
          nextBtn.disabled = currentStep === frames.length - 1;
        }

        function buildDots() {
          dotsEl.innerHTML = frames.map((_, i) =>
            `<button class="sol-dot${i === 0 ? ' active' : ''}" data-step="${i}" aria-label="Step ${i + 1}"></button>`
          ).join('');
          dotsEl.querySelectorAll<HTMLButtonElement>('.sol-dot').forEach((d) => {
            d.addEventListener('click', () => { pause(); showFrame(parseInt(d.dataset.step!)); });
          });
        }

        // ── Shared array / vars grid (viz + solution dry run) ──
        function buildCellsVarsHtml(
          cells: Array<{ v: string | number; s?: string; p?: string }>,
          vars: Array<{ k: string; v: string | number; hi?: boolean }>
        ): string {
          if (!cells.length) return '';
          const cellsHtml = cells.map(
            (c, i) =>
              `<div class="viz-cell viz-${c.s || 'n'}" style="animation-delay:${i * 0.052}s">${escHtml(String(c.v))}</div>`
          ).join('');
          const labelsHtml = cells.map((c) =>
            `<div class="viz-ptr">${c.p ? `<span class="viz-arrow">↑</span><span>${escHtml(c.p.replace(/↑\s*/g, ''))}</span>` : ''}</div>`
          ).join('');
          const varsHtml = vars.map((v) =>
            `<span class="viz-var${v.hi ? ' viz-hi' : ''}">${escHtml(v.k)}<span class="viz-eq"> = </span><strong>${escHtml(String(v.v))}</strong></span>`
          ).join('');
          return `<div class="viz-array-grid" style="grid-template-columns:repeat(${cells.length},1fr)">${cellsHtml}${labelsHtml}</div>${varsHtml ? `<div class="viz-vars">${varsHtml}</div>` : ''}`;
        }

        function renderVizFrame(frame: any): string {
          const cells = (frame.cells || []) as Array<{ v: string | number; s?: string; p?: string }>;
          const vars = (frame.vars || []) as Array<{ k: string; v: string | number; hi?: boolean }>;
          return buildCellsVarsHtml(cells, vars);
        }

        /** Map solution step index → viz frame index when counts differ. */
        function vizIdxForSolStep(solIdx: number): number {
          const vn = vizFrameList.length;
          const sn = frames.length;
          if (vn <= 0 || sn <= 0) return 0;
          if (sn <= 1) return 0;
          if (vn >= sn) return Math.min(solIdx, vn - 1);
          return Math.round((solIdx * (vn - 1)) / (sn - 1));
        }

        function renderPairedExample(solIdx: number) {
          if (mode !== 'both' || !vizFrameList.length) return;
          const fi = vizIdxForSolStep(solIdx);
          const frame = vizFrameList[fi];
          if (!frame) return;
          vizLabel.textContent = frame.title || '';
          vizWrap.style.opacity = '1';
          vizWrap.innerHTML = renderVizFrame(frame);
          vizNote.textContent = frame.note || '';
        }

        function updateSolDryPanel(step: any) {
          const dry = step.dry as { caption?: string; cells?: any[]; vars?: any[]; auxTitle?: string; auxLines?: string[] } | undefined;
          const showAside = solutionHasAnyDry && stepHasDrySnapshot(dry);
          solSplitEl.classList.toggle('sol-split--wide', showAside);
          solDryAside.style.display = showAside ? '' : 'none';
          if (!showAside) {
            solDryCaption.textContent = '';
            solDryFrame.innerHTML = '';
            solDryAux.textContent = '';
            solDryAux.style.display = 'none';
            return;
          }
          solDryCaption.textContent = dry!.caption || '';
          solDryFrame.innerHTML = dry!.cells?.length ? buildCellsVarsHtml(dry!.cells, dry!.vars || []) : '';
          if (dry!.auxLines?.length) {
            solDryAux.style.display = 'block';
            solDryAux.textContent = (dry!.auxTitle ? `${dry!.auxTitle}\n` : '') + dry!.auxLines.join('\n');
          } else {
            solDryAux.style.display = 'none';
            solDryAux.textContent = '';
          }
        }

        function showVizFrame(idx: number) {
          stopAll();
          currentStep = Math.max(0, Math.min(idx, frames.length - 1));
          const frame = frames[currentStep];
          syncControls();
          vizLabel.textContent = frame.title;
          vizWrap.style.opacity = '1';
          vizWrap.innerHTML = renderVizFrame(frame);
          vizNote.textContent = frame.note;
          if (isPlaying) {
            const dwellAt = currentStep;
            if (dwellAt < frames.length - 1) {
              advTimer = window.setTimeout(() => {
                if (!isPlaying || currentStep !== dwellAt) return;
                showVizFrame(dwellAt + 1);
              }, atSpeed(1650, 120));
            } else {
              isPlaying = false;
              ppBtn.textContent = '▶';
            }
          }
        }

        // ── Sol renderer (typewriter) ──
        function typeCode(text: string, onDone: () => void, msPerChar?: number) {
          stopAll();
          codeEl.textContent = '';
          codeEl.classList.remove('typing');
          if (!text.length) {
            queueMicrotask(onDone);
            return;
          }
          codeEl.classList.add('typing');
          let i = 0;
          const n = text.length;
          const adaptive =
            msPerChar ??
            (playbackExpanded
              ? Math.max(5, Math.min(12, Math.floor(2100 / Math.max(n, 100))))
              : Math.max(4, Math.min(11, Math.floor(1300 / Math.max(n, 72)))));
          const tickMs = atSpeed(adaptive, 1);
          twTimer = window.setInterval(() => {
            if (i < text.length) {
              codeEl.textContent += text[i++];
            } else {
              clearInterval(twTimer);
              codeEl.classList.remove('typing');
              onDone();
            }
          }, tickMs);
        }

        function solStepDwellMs(codeLen: number): number {
          let base: number;
          if (playbackExpanded) {
            base = Math.min(5000, Math.max(2200, codeLen * 20 + 700));
          } else {
            base = Math.min(3600, Math.max(1100, codeLen * 13 + 350));
          }
          return atSpeed(base, 100);
        }

        function solutionStepCodeText(step: any): string {
          const c = step?.code;
          if (Array.isArray(c)) return c.join('\n');
          if (c == null) return '';
          return String(c);
        }

        /** After typing finishes: wait, then next step (only if still playing & same step). */
        function scheduleSolAdvanceAfterDwell(finishedIdx: number, codeLen: number) {
          if (!isPlaying) return;
          advTimer = window.setTimeout(() => {
            if (!isPlaying || currentStep !== finishedIdx) return;
            if (finishedIdx < frames.length - 1) showSolStep(finishedIdx + 1);
            else {
              isPlaying = false;
              ppBtn.textContent = '▶';
            }
          }, solStepDwellMs(codeLen));
        }

        function showSolStep(idx: number) {
          stopAll();
          currentStep = Math.max(0, Math.min(idx, frames.length - 1));
          const step = frames[currentStep];
          syncControls();
          if (mode === 'both') renderPairedExample(currentStep);
          stepTitle.textContent = step.title;
          const prose = getStepExplain(step);
          const splitWords = stepHasProseAside(step);
          solWordCodeEl.classList.toggle('sol-word-code--split', splitWords);
          solExplainEl.textContent = splitWords ? prose : '';
          noteEl.classList.remove('visible');
          const noteRaw = String(step.note ?? '').trim();
          noteEl.textContent = noteRaw;
          updateSolDryPanel(step);
          const codeText = solutionStepCodeText(step);
          const stepIdx = currentStep;
          typeCode(codeText, () => {
            if (noteRaw) noteEl.classList.add('visible');
            if (isPlaying) {
              if (stepIdx < frames.length - 1) scheduleSolAdvanceAfterDwell(stepIdx, codeText.length);
              else {
                isPlaying = false;
                ppBtn.textContent = '▶';
              }
            }
          });
        }

        // ── Unified dispatch ──
        function showFrame(idx: number) {
          if (mode === 'viz') showVizFrame(idx);
          else showSolStep(idx);
        }

        function pause() { isPlaying = false; ppBtn.textContent = '▶'; stopAll(); }

        function play() {
          isPlaying = true;
          ppBtn.textContent = '⏸';
          if (mode === 'viz') {
            showFrame(currentStep);
            return;
          }
          const step = frames[currentStep];
          if (!step) {
            showFrame(currentStep);
            return;
          }
          const codeText = solutionStepCodeText(step);
          const noteText = String(step.note ?? '').trim();
          const noteOk =
            !noteText
            || (noteEl.classList.contains('visible') && noteEl.textContent.trim() === noteText);
          const fullyShown =
            !codeEl.classList.contains('typing')
            && codeEl.textContent === codeText
            && noteOk;
          if (fullyShown) {
            if (currentStep < frames.length - 1) scheduleSolAdvanceAfterDwell(currentStep, codeText.length);
            else {
              isPlaying = false;
              ppBtn.textContent = '▶';
            }
            return;
          }
          showFrame(currentStep);
        }

        /** Split key insight into fine-grained beats (also used by sync script idea). */
        function parseInsightSegments(insight: string): string[] {
          let t = insight.trim().replace(/\u2192/g, '→').replace(/\s*->\s*/g, '→');
          if (!t) return [];
          let chunks: string[] = [];
          if (t.includes('→')) chunks = t.split('→').map((s) => s.trim()).filter(Boolean);
          else if (t.includes(';')) chunks = t.split(';').map((s) => s.trim()).filter(Boolean);
          else if (t.length > 36 && /\s\|\s/.test(t)) chunks = t.split(/\s\|\s/).map((s) => s.trim()).filter(Boolean);
          else chunks = [t];

          const out: string[] = [];
          for (const c of chunks) {
            if (c.length > 130 && c.includes('. ')) {
              out.push(...c.split(/(?<=\.)\s+/).map((s) => s.trim()).filter(Boolean));
            } else if (c.length > 85 && /,\s+/.test(c) && !/\bO\(/.test(c)) {
              const bits = c.split(/,\s+/).map((s) => s.trim()).filter(Boolean);
              if (bits.length > 1) out.push(...bits);
              else out.push(c);
            } else out.push(c);
          }
          return out.filter(Boolean);
        }

        function shortInsightTitle(s: string, max = 56): string {
          const one = s.replace(/\s+/g, ' ').trim();
          if (one.length <= max) return one;
          return one.slice(0, max - 1) + '…';
        }

        function insightNoteToCodeLines(note: string): string[] {
          const words = note.replace(/\s+/g, ' ').trim().split(/\s+/);
          const lines: string[] = [];
          let buf = '# ';
          for (const w of words) {
            if (!w) continue;
            if ((buf + w).length > 72) {
              lines.push(buf.trimEnd());
              buf = '# ' + w + ' ';
            } else buf += w + ' ';
          }
          const last = buf.trimEnd();
          if (last !== '#') lines.push(last);
          return lines.length ? lines : ['# ' + note];
        }

        function inferMicroHint(segment: string, ctx: string): string | null {
          const s = (segment + ' ' + ctx).toLowerCase();
          if (/invariant|eliminate|discard|search space|monotone/.test(s)) return 'Each step removes impossible candidates — the invariant tells you what is still possible.';
          if (/two pointer|lo.*hi|left.*right|opposite/.test(s)) return 'Only move the pointer that cannot discard the answer yet; the other side stays a valid candidate.';
          if (/binary|mid|half/.test(s)) return 'Compare mid to target or boundary — one side is always sorted or safe to drop.';
          if (/window|subarray|substring/.test(s)) return 'Grow the window while valid, shrink from the left while invalid — amortized O(n).';
          if (/hash|map|frequency|counter/.test(s)) return 'Turn “have I seen this?” into O(1) lookup — trade space for time.';
          if (/stack|monotonic/.test(s)) return 'The stack orders candidates so the next useful element is always on top.';
          if (/dp|memo|optimal sub/.test(s)) return 'Reuse answers to smaller prefixes — define state so overlaps appear.';
          if (/bfs|queue|level/.test(s)) return 'Process layers in order — first time you reach a node is often shortest path.';
          if (/dfs|recurs|backtrack/.test(s)) return 'Try choices, undo on failure — prune when constraints break.';
          if (/greedy|sort.*then/.test(s)) return 'Make the locally safe choice that cannot block a global optimum (when the structure allows it).';
          return null;
        }

        type SynthStep = { title: string; code: string[]; note: string; phase?: string };

        /** Pattern vocabulary — gives viewers a mental scaffold before line-by-line insight. */
        function patternPrimers(title: string, insight: string): SynthStep[] {
          const s = (title + ' ' + insight).toLowerCase();
          const primers: SynthStep[] = [];

          const add = (title: string, code: string[], note: string, phase: string) => {
            primers.push({ title, code, note, phase });
          };

          if (/binary search|bisect|\bmid\b.*\b(sorted|half)/.test(s) || (/sorted/.test(s) && /\blog\b|\(\s*lo|\bhi\b/.test(s))) {
            add(
              'Pattern · halving the search space',
              [
                '# Binary search mindset',
                '# Maintain an interval [lo, hi] that MUST still contain the answer.',
                '# Pick mid = (lo + hi) // 2  (watch overflow variants in code)',
                '# Compare / check mid → discard one half → repeat.',
                '# Stop when lo meets hi or you found the probe point.',
              ],
              'Every comparison removes roughly half of remaining possibilities — that is why we get logarithmic depth.',
              'Pattern'
            );
          } else if (/two pointer|two-pointer|opposite|left.*right|\blo\b.*\bhi\b/.test(s)) {
            add(
              'Pattern · two moving boundaries',
              [
                '# Two-pointer scaffold',
                '# Place pointers at meaningful ends (0 and n-1, or both array heads).',
                '# Each step: use the problem rule to advance ONE pointer.',
                '# The rule is usually monotone — you never undo a dismissal.',
                '# Stop when pointers cross or meet the success condition.',
              ],
              'You are proving an invariant about what lies between the pointers while shrinking the unknown region.',
              'Pattern'
            );
          } else if (/sliding window|subarray|substring|consecutive/.test(s)) {
            add(
              'Pattern · expanding / contracting window',
              [
                '# Sliding window scaffold',
                '# right (or end) grows while the window is “allowed”.',
                '# When it breaks validity, move left (start) forward until valid again.',
                '# Track the aggregate you care about (sum, counts, uniqueness).',
              ],
              'Each index enters and leaves the window at most once — typically linear time overall.',
              'Pattern'
            );
          } else if (/fast.*slow|floyd|cycle/.test(s)) {
            add(
              'Pattern · fast / slow pointers',
              [
                '# Floyd-style movement',
                '# slow += 1 step per tick; fast += 2 (or k vs 1).',
                '# If there is a cycle, fast eventually laps slow inside the loop.',
                '# For entry detection: after meet, reset one pointer to head.',
              ],
              'Relative speed creates a meeting point that encodes structural facts about the list.',
              'Pattern'
            );
          } else if (/hash|map|dictionary|frequency|counter/.test(s)) {
            add(
              'Pattern · dictionary / counts',
              [
                '# Hash map recipe',
                '# Choose key = the piece you need to look up in O(1).',
                '# Update structure as you scan; check complement / balance as you go.',
                '# Space pays for time — bounded by alphabet or distinct elements.',
              ],
              'If the bottleneck is repeated lookup, a map turns linear scans into constant checks.',
              'Pattern'
            );
          } else if (/monotonic stack|stack/.test(s)) {
            add(
              'Pattern · stack of candidates',
              [
                '# Stack intuition',
                '# Push while maintaining order / usefulness.',
                '# Pop when the new element invalidates old candidates.',
                '# The answer for “next greater / nearest …” often sits at stack top.',
              ],
              'You delay decisions until future input proves which past items are irrelevant.',
              'Pattern'
            );
          } else if (/\bbfs\b|queue|level-order|shortest.*unweighted/.test(s)) {
            add(
              'Pattern · breadth-first traversal',
              [
                '# BFS sketch',
                '# Queue stores frontier; dequeue → explore neighbors.',
                '# Mark visited to avoid cycles.',
                '# First dequeue of a target often yields shortest path in unweighted graphs.',
              ],
              'Layers expand uniformly — distance increases one edge at a time.',
              'Pattern'
            );
          } else if (/\bdfs\b|backtrack|recurs/.test(s)) {
            add(
              'Pattern · depth-first / backtracking',
              [
                '# DFS / backtrack sketch',
                '# Choose → recurse → if dead end, undo last choice.',
                '# Prune early when constraints fail.',
                '# Memoize when the same sub-state appears from different paths.',
              ],
              'You explore one complete branch before switching — stack frames mirror the recursion tree.',
              'Pattern'
            );
          } else if (/\bdp\b|memo|optimal sub/.test(s)) {
            add(
              'Pattern · dynamic programming',
              [
                '# DP checklist',
                '# 1) Define state[i] or dp[i][j] as the optimum for a prefix/subproblem.',
                '# 2) Write recurrence using smaller indices.',
                '# 3) Pick order so dependencies are ready (bottom-up) or memo top-down.',
              ],
              'Overlapping subproblems mean brute-force recursion explodes — tables reuse work.',
              'Pattern'
            );
          }

          return primers.slice(0, 2);
        }

        function buildRichInsightStep(part: string, i: number, total: number, ctx: string): SynthStep {
          const hint = inferMicroHint(part, ctx);
          const code: string[] = [
            `# ─── Logic ${i + 1} / ${total} ───`,
            '#',
            ...insightNoteToCodeLines(part),
          ];
          if (hint) {
            code.push('#', `# Insight: ${hint}`);
          }
          return {
            title: shortInsightTitle(part),
            code,
            note: hint ? `${part}\n\nWhy it fits: ${hint}` : part,
            phase: 'Execution',
          };
        }

        /** Multi-phase walkthrough when no hand-authored solution exists. */
        function buildSyntheticSolutionSteps(insight: string, title: string): SynthStep[] {
          let parts = parseInsightSegments(insight);
          if (parts.length > 10) {
            parts = parts.slice(0, 9).concat(parts.slice(9).join(' · '));
          }
          if (parts.length === 0) {
            return [
              {
                title: 'Open the statement',
                code: [
                  '# No key insight text is stored for this row yet.',
                  '# On LeetCode: read constraints → try one example by hand → note the bottleneck.',
                  '# Common angles: brute force bound → sort → two pointers / binary search / hash map.',
                ],
                note: 'Once your Supabase row has key_insight text, this overlay will expand it into a full animated walkthrough.',
                phase: 'Setup',
              },
            ];
          }

          const ctx = parts.join(' ');
          const primers = patternPrimers(title, insight);
          const steps: SynthStep[] = [];

          for (const p of primers) steps.push(p);

          steps.push({
            title: `Goal · ${shortInsightTitle(title, 44)}`,
            code: [
              '# What we are proving / computing',
              `# Problem focus: ${title}`,
              '#',
              ...insightNoteToCodeLines(parts[0]),
              ...(parts.length > 1 ? ['#', '# (Additional moves follow in the next steps.)'] : []),
            ],
            note: '',
            phase: 'Goal',
          });

          parts.forEach((part, i) => {
            steps.push(buildRichInsightStep(part, i, parts.length, ctx));
          });

          steps.push({
            title: 'Recap · chain the story',
            code: [
              '# End-to-end narrative (say this once fluently):',
              ...parts.flatMap((p, j) => [`# ${j + 1}. ${shortInsightTitle(p, 68)}`]),
              '#',
              '# Tip: name the invariant or the quantity you minimize/maximize — interviewers listen for that.',
            ],
            note: parts.length > 1
              ? `Single thread: ${parts.map((p) => shortInsightTitle(p, 42)).join(' → ')}`
              : 'One core idea drives the whole solution — rehearse it until it feels obvious.',
            phase: 'Recap',
          });

          return steps;
        }

        // ── Open overlay ──
        async function openOverlay(lcNum: string, title: string, insight: string, problemId?: string) {
          badge.textContent   = lcNum ? `LC ${lcNum}` : '';
          titleEl.textContent = title;

          let viz: { frames?: any[] } | null = null;
          let sol: { approach?: string; time?: string; space?: string; steps?: any[] } | null = null;

          if (problemId) {
            const { data: pb } = await supabase
              .from('problem_playback')
              .select('solution, visualization')
              .eq('problem_id', problemId)
              .maybeSingle();
            const vis = pb?.visualization;
            if (vis && typeof vis === 'object' && Array.isArray((vis as { frames?: unknown }).frames)) {
              const fr = (vis as { frames: unknown[] }).frames;
              if (fr.length) viz = vis as { frames: any[] };
            }
            const s = pb?.solution;
            if (s && typeof s === 'object' && Array.isArray((s as { steps?: unknown }).steps)) {
              const st = (s as { steps: unknown[] }).steps;
              if (st.length) sol = s as typeof sol;
            }
          }

          const hasViz = Boolean(viz?.frames?.length);
          const hasSolSteps = Boolean(sol?.steps?.length);

          if (hasViz && hasSolSteps) {
            // ── Example + walkthrough side by side (timeline = solution steps) ──
            mode = 'both';
            vizFrameList = viz!.frames;
            frames = sol!.steps!;
            vizView.style.display = 'block';
            solView.style.display = 'block';
            vizView.classList.add('viz-view--paired');
            insightPanel.classList.add('insight-panel--example-split');
            fallback.style.display = 'none';
            controls.style.display = 'flex';
            applyResolvedComplexity(lcNum, title, insight, sol);
            solutionHasAnyDry = frames.some((s: any) => stepHasDrySnapshot(s.dry));
            playbackExpanded = frames.length >= 12;
            currentStep = 0;
            isPlaying = true;
            buildDots();
            ppBtn.textContent = '⏸';
            showSolStep(0);
          } else if (hasViz) {
            // ── Visualization only ──
            mode = 'viz';
            vizFrameList = [];
            vizView.classList.remove('viz-view--paired');
            insightPanel.classList.remove('insight-panel--example-split');
            vizView.style.display = 'block';
            solView.style.display = 'none';
            fallback.style.display = 'none';
            controls.style.display = 'flex';
            applyResolvedComplexity(lcNum, title, insight, null);
            frames = viz!.frames;
            currentStep = 0;
            isPlaying = true;
            buildDots();
            ppBtn.textContent = '⏸';
            showVizFrame(0);
          } else {
            // ── Solution-only or synthesized insight ──
            if (!sol?.steps?.length) {
              sol = {
                approach: 'Key insight',
                time: '—',
                space: '—',
                steps: buildSyntheticSolutionSteps(insight, title),
              };
            }
            mode = 'sol';
            vizFrameList = [];
            vizView.classList.remove('viz-view--paired');
            insightPanel.classList.remove('insight-panel--example-split');
            vizView.style.display = 'none';
            solView.style.display = 'block';
            fallback.style.display = 'none';
            controls.style.display = 'flex';
            applyResolvedComplexity(lcNum, title, insight, sol);
            frames = sol!.steps!;
            solutionHasAnyDry = frames.some((s: any) => stepHasDrySnapshot(s.dry));
            playbackExpanded = frames.length >= 12;
            currentStep = 0;
            isPlaying = true;
            buildDots();
            ppBtn.textContent = '⏸';
            showSolStep(0);
          }

          overlay.classList.add('active');
          document.body.style.overflow = 'hidden';
        }

        function closeOverlay() {
          overlay.classList.remove('active');
          document.body.style.overflow = '';
          stopAll(); isPlaying = false;
          vizFrameList = [];
          vizView.classList.remove('viz-view--paired');
          insightPanel.classList.remove('insight-panel--example-split');
          setInsightChips('—', '—');
          solutionHasAnyDry = false;
          solSplitEl.classList.remove('sol-split--wide');
          solDryAside.style.display = '';
          solDryCaption.textContent = '';
          solDryFrame.innerHTML = '';
          solDryAux.textContent = '';
          solDryAux.style.display = 'none';
        }

        prevBtn.addEventListener('click', () => { pause(); showFrame(currentStep - 1); });
        nextBtn.addEventListener('click', () => { pause(); showFrame(currentStep + 1); });
        ppBtn.addEventListener('click',   () => { isPlaying ? pause() : play(); });

        overlay.addEventListener('click', (e) => { if (e.target === overlay) closeOverlay(); });
        overlay.querySelector('.insight-close')!.addEventListener('click', closeOverlay);
        document.addEventListener('keydown', (e) => {
          if (!overlay.classList.contains('active')) return;
          if (e.key === 'Escape')      { closeOverlay(); return; }
          if (e.key === 'ArrowRight')  { pause(); showFrame(currentStep + 1); }
          if (e.key === 'ArrowLeft')   { pause(); showFrame(currentStep - 1); }
          if (e.key === ' ') { e.preventDefault(); isPlaying ? pause() : play(); }
        });

        document.querySelectorAll('td.insight-clickable').forEach((cell) => {
          const text = cell.textContent?.trim();
          if (!text) return;
          (cell as HTMLElement).title = isPaid ? 'Open walkthrough' : 'Pro: full walkthrough';
          cell.addEventListener('click', () => {
            const row = cell.closest('tr')!;
            const lcNum = (row.querySelector('.lc-link')?.textContent || '').match(/\d+/)?.[0] || '';
            const title = row.querySelector('.prob-name')?.textContent?.replace(/^⚠️\s*/, '').trim() || '';
            if (!isPaid) {
              openInsightProGate(lcNum, title);
              return;
            }
            const problemId = row.getAttribute('data-problem-id') || '';
            openOverlay(lcNum, title, text, problemId);
          });
        });
      })();

      // ── Mobile Nav ──
      document.getElementById('mob-nav-btn')!.addEventListener('click', () => {
        document.getElementById('sidebar')!.classList.toggle('open');
      });

      // ── Show first topic ──
      const firstNav = document.querySelector('.nav-item');
      if (firstNav) show(parseInt(firstNav.getAttribute('data-topic-id')!), firstNav);
    </script>
  </body>
</html>
