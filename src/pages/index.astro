<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DSA Mastery Guide</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@300..700&display=swap" rel="stylesheet">
    <style>
        :root,[data-theme="light"]{
            --bg:#f7f6f2;--surface:#f9f8f5;--surface2:#fbfbf9;--offset:#f3f0ec;
            --divider:#dcd9d5;--border:#d4d1ca;
            --text:#28251d;--muted:#7a7974;--faint:#bab9b4;--inv:#f9f8f4;
            --primary:#01696f;--primary-h:#0c4e54;
            --error:#a12c7b;--warn:#964219;
            --shadow:0 4px 16px rgba(40,37,29,.09);
            --radius:.5rem;
        }
        [data-theme="dark"]{
            --bg:#0f0e0d;--surface:#161513;--surface2:#1c1b19;--offset:#1d1c1a;
            --divider:#262523;--border:#2e2d2b;
            --text:#cdccca;--muted:#797876;--faint:#5a5957;--inv:#2b2a28;
            --primary:#4f98a3;--primary-h:#227f8b;
            --error:#d163a7;--warn:#bb653b;
            --shadow:0 4px 24px rgba(0,0,0,.45);
        }
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
        body{font-family:'Inter',sans-serif;font-size:.875rem;background:var(--bg);color:var(--text);line-height:1.6;min-height:100dvh}
        a{color:var(--primary);text-decoration:none}
        a:hover{text-decoration:underline}
        table{border-collapse:collapse;width:100%}
        button{cursor:pointer;background:none;border:none;color:inherit;font:inherit}

        /* ── LAYOUT ── */
        .app{display:flex;min-height:100dvh}
        .sidebar{width:260px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:sticky;top:0;height:100dvh;overflow-y:auto}
        .main{flex:1;min-width:0;overflow-x:hidden}

        /* ── SIDEBAR ── */
        .logo{padding:1.2rem 1.1rem .8rem;border-bottom:1px solid var(--divider);display:flex;align-items:center;gap:.6rem}
        .logo svg{flex-shrink:0}
        .logo-text{font-size:.95rem;font-weight:700;letter-spacing:-.01em}
        .logo-sub{font-size:.68rem;color:var(--muted)}
        .nav-section{padding:.6rem .7rem .3rem;font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--faint)}
        .nav-item{display:flex;align-items:center;gap:.55rem;padding:.45rem .8rem;border-radius:.4rem;margin:1px .4rem;cursor:pointer;font-size:.8rem;transition:background .15s,color .15s;color:var(--muted);border:none;background:none;width:calc(100% - .8rem);text-align:left}
        .nav-item:hover{background:var(--offset);color:var(--text)}
        .nav-item.active{background:color-mix(in oklab,var(--primary) 12%,var(--surface));color:var(--primary);font-weight:600}
        .nav-item .num{font-size:.68rem;font-weight:700;min-width:1.4rem;color:var(--faint)}
        .nav-item.active .num{color:var(--primary)}
        .nav-item .tier-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-left:auto}
        .sidebar-footer{margin-top:auto;padding:.8rem;border-top:1px solid var(--divider);display:flex;align-items:center;justify-content:space-between}
        .theme-btn{display:flex;align-items:center;gap:.4rem;font-size:.72rem;color:var(--muted);padding:.3rem .5rem;border-radius:.35rem;transition:background .15s}
        .theme-btn:hover{background:var(--offset);color:var(--text)}
        .progress-summary{font-size:.68rem;color:var(--faint)}

        /* ── TOPBAR ── */
        .topbar{position:sticky;top:0;z-index:10;background:var(--surface);border-bottom:1px solid var(--border);padding:.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between;backdrop-filter:blur(8px)}
        .topbar-title{font-size:1rem;font-weight:700;letter-spacing:-.01em}
        .topbar-meta{font-size:.72rem;color:var(--muted)}
        .search-box{display:flex;align-items:center;gap:.5rem;background:var(--offset);border:1px solid var(--border);border-radius:.45rem;padding:.3rem .65rem;font-size:.78rem;color:var(--muted);width:220px}
        .search-box input{background:none;border:none;outline:none;color:var(--text);font:inherit;width:100%}
        .search-box input::placeholder{color:var(--faint)}

        /* ── CONTENT ── */
        .content{padding:1.5rem;max-width:1400px}
        .topic-card{display:none;animation:fadeIn .2s ease}
        .topic-card.active{display:block}
        @keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

        .topic-header{display:flex;align-items:flex-start;gap:1rem;padding:1.25rem 1.5rem;background:var(--surface);border:1px solid var(--border);border-radius:.6rem .6rem 0 0;border-bottom:none}
        .topic-num{font-size:2.5rem;font-weight:800;color:var(--border);line-height:1;font-family:'JetBrains Mono',monospace;min-width:3.5rem}
        .topic-title{font-size:1.35rem;font-weight:800;letter-spacing:-.02em;margin-bottom:.25rem}
        .topic-meta{font-size:.72rem;color:var(--muted)}
        .topic-body{background:var(--surface);border:1px solid var(--border);border-radius:0 0 .6rem .6rem;padding:1.25rem 1.5rem;display:flex;flex-direction:column;gap:1.1rem}

        .tier-badge{font-size:.62rem;font-weight:700;padding:.18rem .55rem;border-radius:999px;text-transform:uppercase;letter-spacing:.07em}
        .tier-T1{background:color-mix(in oklab,#01696f 15%,var(--surface));color:#01696f}
        .tier-T2{background:color-mix(in oklab,#7a39bb 15%,var(--surface));color:#7a39bb}
        .tier-T3{background:color-mix(in oklab,#da7101 15%,var(--surface));color:#da7101}
        .tier-T4{background:color-mix(in oklab,#a13544 15%,var(--surface));color:#a13544}
        .tier-T5{background:color-mix(in oklab,#006494 15%,var(--surface));color:#006494}
        .topic-type{font-size:.65rem;color:var(--muted);background:var(--offset);padding:.15rem .45rem;border-radius:.3rem;font-weight:500}

        .info-box{background:color-mix(in oklab,var(--primary) 8%,var(--surface));border-left:3px solid var(--primary);padding:.65rem .95rem;border-radius:0 .45rem .45rem 0;font-size:.82rem}
        .core-box{background:color-mix(in oklab,#7a39bb 8%,var(--surface));border-left:3px solid #7a39bb;padding:.65rem .95rem;border-radius:0 .45rem .45rem 0;font-size:.82rem}

        .sec-title{font-size:.68rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;padding-bottom:.4rem;border-bottom:1px solid var(--divider)}

        /* ── PILLS ── */
        .pill-grid{display:flex;flex-wrap:wrap;gap:.35rem}
        .pill{font-size:.7rem;background:var(--offset);border:1px solid var(--border);color:var(--text);padding:.2rem .55rem;border-radius:999px;white-space:nowrap}

        /* ── TABLE ── */
        .tbl-wrap{overflow-x:auto;border-radius:.5rem;border:1px solid var(--border)}
        table thead tr{background:var(--surface2)}
        table th{padding:.45rem .65rem;text-align:left;font-size:.64rem;color:var(--faint);text-transform:uppercase;letter-spacing:.08em;border-bottom:1px solid var(--border);white-space:nowrap}
        table td{padding:.42rem .65rem;border-bottom:1px solid var(--divider);vertical-align:top;font-size:.78rem}
        table tbody tr:last-child td{border-bottom:none}
        table tbody tr:hover{background:var(--offset)}
        .num-cell{color:var(--faint);font-family:'JetBrains Mono',monospace;font-size:.7rem;white-space:nowrap}
        .prob-name{font-weight:500;max-width:200px}
        .trap-name{color:var(--error);font-weight:600}
        .variant-cell{color:var(--primary);font-size:.75rem;max-width:180px}
        .insight{color:var(--muted);font-style:italic;font-size:.74rem;max-width:320px}
        .lc-link{font-size:.72rem;font-family:'JetBrains Mono',monospace;white-space:nowrap;color:var(--primary)}
        .lc-link:hover{color:var(--primary-h)}

        /* ── LAYER BADGES ── */
        .l1{background:#dbeafe;color:#1e40af;font-size:.62rem;font-weight:700;padding:.12rem .4rem;border-radius:999px;white-space:nowrap}
        .l2{background:#dcfce7;color:#166534;font-size:.62rem;font-weight:700;padding:.12rem .4rem;border-radius:999px;white-space:nowrap}
        .l3{background:#fef9c3;color:#854d0e;font-size:.62rem;font-weight:700;padding:.12rem .4rem;border-radius:999px;white-space:nowrap}
        .l4{background:#ffedd5;color:#9a3412;font-size:.62rem;font-weight:700;padding:.12rem .4rem;border-radius:999px;white-space:nowrap}
        .l5{background:#fee2e2;color:#991b1b;font-size:.62rem;font-weight:700;padding:.12rem .4rem;border-radius:999px;white-space:nowrap}
        [data-theme="dark"] .l1{background:rgba(59,130,246,.18);color:#93c5fd}
        [data-theme="dark"] .l2{background:rgba(34,197,94,.15);color:#86efac}
        [data-theme="dark"] .l3{background:rgba(234,179,8,.15);color:#fde047}
        [data-theme="dark"] .l4{background:rgba(249,115,22,.15);color:#fdba74}
        [data-theme="dark"] .l5{background:rgba(239,68,68,.15);color:#fca5a5}

        /* ── DIFF ── */
        .diff-e{color:#15803d;font-weight:600;font-size:.72rem}
        .diff-m{color:#b45309;font-weight:600;font-size:.72rem}
        .diff-h{color:#b91c1c;font-weight:700;font-size:.72rem}
        [data-theme="dark"] .diff-e{color:#4ade80}
        [data-theme="dark"] .diff-m{color:#fbbf24}
        [data-theme="dark"] .diff-h{color:#f87171}
        .prem{font-size:.7rem}

        /* ── COVERAGE / WARN ── */
        .coverage-box{background:color-mix(in oklab,var(--primary) 7%,var(--surface));border:1px solid color-mix(in oklab,var(--primary) 30%,var(--border));border-radius:.45rem;padding:.7rem 1rem;font-size:.82rem;display:flex;flex-wrap:wrap;align-items:center;gap:.4rem}
        .warn-box{background:color-mix(in oklab,var(--error) 7%,var(--surface));border-left:3px solid var(--error);padding:.5rem .85rem;border-radius:0 .45rem .45rem 0;font-size:.79rem;line-height:1.5}
        .coming{background:var(--offset);border:1px dashed var(--border);border-radius:.5rem;padding:2rem;text-align:center;color:var(--muted);font-size:.85rem;line-height:1.8}

        /* ── TRIGGERS TABLE ── */
        .trigger-phrase{font-style:italic;color:var(--primary)}
        .trigger-variant{font-weight:600}
        .trigger-breaks{color:var(--muted)}

        /* ── MOBILE ── */
        .mob-nav-btn{display:none;position:fixed;bottom:1rem;right:1rem;z-index:100;background:var(--primary);color:#fff;border-radius:50%;width:44px;height:44px;align-items:center;justify-content:center;box-shadow:var(--shadow)}
        @media(max-width:768px){
            .sidebar{position:fixed;left:-270px;top:0;height:100%;z-index:50;transition:left .25s}
            .sidebar.open{left:0}
            .main{width:100%}
            .mob-nav-btn{display:flex}
            .content{padding:1rem}
            .topic-header{flex-direction:column;gap:.5rem}
            .topic-num{font-size:1.8rem}
            .prob-name{max-width:140px}
            .insight{max-width:200px}
        }
    </style>
</head>
<body>
<div class="app">

    <!-- SIDEBAR -->
    <nav class="sidebar" id="sidebar">
        <div class="logo">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <rect width="28" height="28" rx="6" fill="#01696f"/>
                <path d="M7 14h4l3-6 3 12 3-6h1" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div>
                <div class="logo-text">DSA Mastery</div>
                <div class="logo-sub">Interview Preparation Guide</div>
            </div>
        </div>

        <div class="nav-section">Foundations</div>
        <button class="nav-item" data-topic-id="1"><span class="num">01</span>Two Pointers<span class="tier-dot" style="background:#01696f"></span></button>
        <button class="nav-item" data-topic-id="2"><span class="num">02</span>HashMap<span class="tier-dot" style="background:#01696f"></span></button>
        <button class="nav-item" data-topic-id="3"><span class="num">03</span>Binary Search<span class="tier-dot" style="background:#01696f"></span></button>

        <div class="nav-section">Core DSA</div>
        <button class="nav-item" data-topic-id="4"><span class="num">04</span>Sliding Window<span class="tier-dot" style="background:#7a39bb"></span></button>
        <button class="nav-item" data-topic-id="5"><span class="num">05</span>Kadane's Algorithm<span class="tier-dot" style="background:#7a39bb"></span></button>
        <button class="nav-item" data-topic-id="6"><span class="num">06</span>Merge Intervals<span class="tier-dot" style="background:#7a39bb"></span></button>

        <div class="nav-section">Advanced</div>
        <button class="nav-item" data-topic-id="7"><span class="num">07</span>Prefix Sums<span class="tier-dot" style="background:#da7101"></span></button>

        <div class="sidebar-footer">
            <button class="theme-btn" aria-label="Toggle theme">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                Theme
            </button>
            <span class="progress-summary">7 Topics</span>
        </div>
    </nav>

    <!-- MAIN -->
    <div class="main">
        <div class="topbar">
            <div>
                <div class="topbar-title" id="topbar-title"></div>
                <div class="topbar-meta" id="topbar-meta"></div>
            </div>
            <div class="search-box">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                <input type="text" id="searchInput" placeholder="Filter problems…">
            </div>
        </div>

        <div class="content">

            <!-- ══════════════════════════════════════════
                 TOPIC 1 — TWO POINTERS
            ═══════════════════════════════════════════ -->
            <div class="topic-card" id="tp1">
                <div class="topic-header">
                    <div class="topic-num">01</div>
                    <div style="flex:1">
                        <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap">
                            <div class="topic-title">Two Pointers</div>
                            <span class="tier-badge tier-T1">Foundation</span>
                            <span class="topic-type">Technique</span>
                        </div>
                        <div class="topic-meta">54 problems · sorted array, linked list, string</div>
                    </div>
                </div>
                <div class="topic-body">
                    <div class="info-box"><strong>Why It Matters:</strong> Tests ability to eliminate search space using invariants. O(n) solutions to O(n²) problems demonstrate insight, not brute force.</div>
                    <div class="core-box"><strong>Core Idea:</strong> Maintain lo/hi (or slow/fast) pointers. Decide which to move based on a monotone condition. The invariant — what you prove about the space between pointers — IS the algorithm.</div>

                    <div class="sec-title">Sub-Variants</div>
                    <div class="pill-grid">
                        <span class="pill">Opposite-end sorted</span><span class="pill">Opposite-end maximize</span><span class="pill">Opposite-end count</span><span class="pill">Three-pointer (3Sum)</span><span class="pill">Four-pointer (4Sum)</span><span class="pill">Dutch National Flag</span><span class="pill">Fast/slow — cycle detection</span><span class="pill">Fast/slow — cycle entry</span><span class="pill">Fast/slow — middle finding</span><span class="pill">Fast/slow — kth from end</span><span class="pill">Fast/slow — palindrome</span><span class="pill">Fast/slow — implicit graph</span><span class="pill">Two pointers on two arrays</span><span class="pill">String two-pointer</span><span class="pill">Fill from ends</span><span class="pill">Two-pointer + sorting</span><span class="pill">Greedy + opposite-end</span><span class="pill">Multi-pointer + heap</span>
                    </div>

                    <div class="sec-title">Problem Set</div>
                    <div class="tbl-wrap"><table>
                        <thead><tr><th>#</th><th>Layer</th><th>Link</th><th>Problem</th><th>Diff</th><th>P</th><th>Sub-Variant</th><th>Key Insight</th></tr></thead>
                        <tbody>
                        <tr><td class="num-cell">1</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/two-sum-ii-input-array-is-sorted/" target="_blank">LC 167</a></td><td class="prob-name">Two Sum II</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Opposite-end sorted</td><td class="insight">lo+hi pointers; move lo up if sum too small, hi down if too large</td></tr>
                        <tr><td class="num-cell">2</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/3sum/" target="_blank">LC 15</a></td><td class="prob-name">3Sum</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Three-pointer (3Sum)</td><td class="insight">Sort; fix i, run opposite-end on [i+1,n-1]; skip duplicates at every level</td></tr>
                        <tr><td class="num-cell">3</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/container-with-most-water/" target="_blank">LC 11</a></td><td class="prob-name">Container With Most Water</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Opposite-end maximize</td><td class="insight">Always move the shorter side — moving the taller can only shrink width without gain</td></tr>
                        <tr><td class="num-cell">4</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/valid-palindrome/" target="_blank">LC 125</a></td><td class="prob-name">Valid Palindrome</td><td><span class="diff-e">Easy</span></td><td></td><td class="variant-cell">String two-pointer</td><td class="insight">Skip non-alphanumeric; compare case-insensitive; lo &lt; hi</td></tr>
                        <tr><td class="num-cell">5</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/linked-list-cycle/" target="_blank">LC 141</a></td><td class="prob-name">Linked List Cycle</td><td><span class="diff-e">Easy</span></td><td></td><td class="variant-cell">Fast/slow — cycle detection</td><td class="insight">Floyd's: if fast meets slow → cycle. fast=head.next.next, slow=head.next</td></tr>
                        <tr><td class="num-cell">6</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/linked-list-cycle-ii/" target="_blank">LC 142</a></td><td class="prob-name">Linked List Cycle II</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Fast/slow — cycle entry</td><td class="insight">After meeting, reset one to head; advance both at speed 1; second meeting = entry</td></tr>
                        <tr><td class="num-cell">7</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/middle-of-the-linked-list/" target="_blank">LC 876</a></td><td class="prob-name">Middle of the Linked List</td><td><span class="diff-e">Easy</span></td><td></td><td class="variant-cell">Fast/slow — middle finding</td><td class="insight">fast=head.next.next, slow=head.next; when fast null → slow is middle</td></tr>
                        <tr><td class="num-cell">8</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/remove-nth-node-from-end-of-list/" target="_blank">LC 19</a></td><td class="prob-name">Remove Nth Node From End of List</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Fast/slow — kth from end</td><td class="insight">Advance fast by n+1; move both until fast null; slow.next = slow.next.next</td></tr>
                        <tr><td class="num-cell">9</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/sort-colors/" target="_blank">LC 75</a></td><td class="prob-name">Sort Colors</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Dutch National Flag</td><td class="variant-cell">Three pointers lo/mid/hi; loop while mid≤hi; 3-way partition in single pass</td></tr>
                        <tr><td class="num-cell">10</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/squares-of-a-sorted-array/" target="_blank">LC 977</a></td><td class="prob-name">Squares of a Sorted Array</td><td><span class="diff-e">Easy</span></td><td></td><td class="variant-cell">Fill from ends</td><td class="insight">Fill result array from right; compare abs(lo) vs abs(hi); advance smaller inward</td></tr>
                        <tr><td class="num-cell">11</td><td><span class="l2">Variants</span></td><td><a class="lc-link" href="https://leetcode.com/problems/4sum/" target="_blank">LC 18</a></td><td class="prob-name">4Sum</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Four-pointer (4Sum)</td><td class="insight">Sort; fix i,j; run opposite-end on remainder; skip all duplicates; watch overflow</td></tr>
                        <tr><td class="num-cell">12</td><td><span class="l2">Variants</span></td><td><a class="lc-link" href="https://leetcode.com/problems/3sum-closest/" target="_blank">LC 16</a></td><td class="prob-name">3Sum Closest</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Three-pointer (3Sum variant)</td><td class="insight">Track min |diff|; update bestSum when closer; same skip pattern as 3Sum</td></tr>
                        <tr><td class="num-cell">13</td><td><span class="l2">Variants</span></td><td><a class="lc-link" href="https://leetcode.com/problems/number-of-subsequences-that-satisfy-the-given-sum-condition/" target="_blank">LC 1498</a></td><td class="prob-name">Number of Subsequences Sum ≤ Target</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Opposite-end count</td><td class="insight">Sort; for each lo, find max hi where nums[lo]+nums[hi]&le;target; add 2^(hi-lo)</td></tr>
                        <tr><td class="num-cell">14</td><td><span class="l2">Variants</span></td><td><a class="lc-link" href="https://leetcode.com/problems/trapping-rain-water/" target="_blank">LC 42</a></td><td class="prob-name">Trapping Rain Water</td><td><span class="diff-h">Hard</span></td><td></td><td class="variant-cell">Fill from ends</td><td class="insight">Track maxLeft, maxRight; water at i = min(maxL,maxR)-height[i]; move smaller side</td></tr>
