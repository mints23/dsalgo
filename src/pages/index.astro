                        <tr><td class="num-cell">2</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/maximum-product-subarray/" target="_blank">LC 152</a></td><td class="prob-name">Maximum Product Subarray</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Product: track max AND min</td><td class="insight">Negative Ã— negative = positive; propagate both maxProd and minProd and swap on each negative element</td></tr>
                        <tr><td class="num-cell">3</td><td><span class="l1">Foundation</span></td><td><a class="lc-link" href="https://leetcode.com/problems/maximum-sum-circular-subarray/" target="_blank">LC 918</a></td><td class="prob-name">Maximum Sum Circular Subarray</td><td><span class="diff-m">Med</span></td><td></td><td class="variant-cell">Circular array</td><td class="insight">Answer = max(normalKadane, totalSum âˆ’ minKadane); edge case: all-negative array â†’ return normalKadane only (circular gives 0)</td></tr>
