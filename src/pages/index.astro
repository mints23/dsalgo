                    <div class="sec-title">Red Flags</div>
                    <div class="warn-box">🚩 <strong>mid = (lo+hi)/2</strong> — classic overflow bug; use mid = lo + (hi-lo)/2 or mid = (lo+hi)&gt;&gt;&gt;1</div>
                    <div class="warn-box">🚩 <strong>lo &lt; hi vs lo &le; hi</strong> — lo &le; hi is generally safer and easier to reason about</div>
                    <div class="warn-box">🚩 <strong>BS on answer space without monotone predicate</strong> — if check(mid) doesn't imply check(mid+1), BS is invalid</div>
                    <div class="warn-box">🚩 <strong>Rotated array duplicate handling</strong> — if nums[lo]==nums[mid]==nums[hi], must do lo++, hi-- to shrink</div>
                    <div class="warn-box">🚩 <strong>Forgetting long for mid*mid</strong> — when checking for sqrt, mid*mid can overflow standard integer types</div>
                    <div class="warn-box">🚩 <strong>Incorrectly identifying the sorted half</strong> — in rotated arrays, the check is crucial: if nums[lo] &lt;= nums[mid]...</div>
                </div></div>

            <!-- ══════════════════════════════════════════
                 TOPIC 4 — SLIDING WINDOW
            ═══════════════════════════════════════════ -->
            <div class="topic-card" id="tp4"><div class="coming">Content for this topic is coming soon.</div></div>
            <div class="topic-card" id="tp5"><div class="coming">Content for this topic is coming soon.</div></div>
            <div class="topic-card" id="tp6"><div class="coming">Content for this topic is coming soon.</div></div>
            <div class="topic-card" id="tp7"><div class="coming">Content for this topic is coming soon.</div></div>

        </div>
    </div>

    <button class="mob-nav-btn" id="mob-nav-btn" aria-label="Open navigation">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
</div>
<script>
    // Theme Toggler
    const themeToggle = document.querySelector('.theme-btn');
    themeToggle.addEventListener('click', () => {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', newTheme);
    });

    // Topic Switching
    const navItems = document.querySelectorAll('.nav-item');
    const topicCards = document.querySelectorAll('.topic-card');
    const topbarTitle = document.getElementById('topbar-title');
    const topbarMeta = document.getElementById('topbar-meta');

    const topicMetas = {
        1: 'Foundation · Technique',
        2: 'Foundation · Data Structure',
        3: 'Foundation · Technique',
        4: 'Core DSA · Technique',
        5: 'Core DSA · Technique',
        6: 'Core DSA · Technique',
        7: 'Advanced · Technique'
    };

    navItems.forEach(item => {
        item.addEventListener('click', () => {
            const topicNum = parseInt(item.getAttribute('data-topic-id'));
            show(topicNum, item);
        });
    });

    function show(topicNum, clickedItem) {
        // Update nav items
        navItems.forEach(item => item.classList.remove('active'));
        clickedItem.classList.add('active');

        // Update topic cards
        topicCards.forEach(card => card.classList.remove('active'));
        const activeCard = document.getElementById(`tp${topicNum}`);
        if (activeCard) {
            activeCard.classList.add('active');
        }

        // Update topbar
        const topicTitle = clickedItem.innerText.replace(/^\\d+\\s*/, '');
        topbarTitle.textContent = topicTitle;
        topbarMeta.textContent = topicMetas[topicNum] || '';

        // Close sidebar on mobile
        const sidebar = document.getElementById('sidebar');
        if (sidebar.classList.contains('open')) {
            sidebar.classList.remove('open');
        }
    }

    // Table Filtering
    const searchInput = document.getElementById('searchInput');
    searchInput.addEventListener('input', filterTable);

    function filterTable() {
        const filter = searchInput.value.toLowerCase();
        const activeCard = document.querySelector('.topic-card.active');
        if (!activeCard) return;

        const table = activeCard.querySelector('table');
        if (!table) return;

        const rows = table.getElementsByTagName('tr');

        for (let i = 1; i < rows.length; i++) { // Start from 1 to skip header
            const cells = rows[i].getElementsByTagName('td');
            let shouldShow = false;
            for (let j = 0; j < cells.length; j++) {
                if (cells[j]) {
                    if (cells[j].innerText.toLowerCase().indexOf(filter) > -1) {
                        shouldShow = true;
                        break;
                    }
                }
            }
            rows[i].style.display = shouldShow ? '' : 'none';
        }
    }

    // Mobile Nav
    const mobNavBtn = document.getElementById('mob-nav-btn');
    const sidebar = document.getElementById('sidebar');
    mobNavBtn.addEventListener('click', () => {
        sidebar.classList.toggle('open');
    });

    // Initialize first view
    document.addEventListener('DOMContentLoaded', () => {
        const firstNavItem = document.querySelector('.nav-item');
        if(firstNavItem) {
           const topicNum = parseInt(firstNavItem.getAttribute('data-topic-id'));
           show(topicNum, firstNavItem);
        }
    });
</script>
</body>
</html>
