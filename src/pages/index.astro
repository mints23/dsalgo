---
import SidebarNav from '../components/SidebarNav.astro';
import Topbar from '../components/Topbar.astro';
import TopicCard from '../components/TopicCard.astro';
import { topics } from '../data/topics';
import '../styles/global.css';

const topicMetas = Object.fromEntries(topics.map((t) => [t.id, t.topbarMeta]));
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Apply theme before paint: saved pref → OS pref → light
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DSA Mastery Guide</title>
    <meta name="description" content="Comprehensive DSA interview preparation guide with 650+ problems across 43 topics — Two Pointers, Binary Search, DP, Graphs, and more." />
    <meta property="og:title" content="DSA Mastery Guide — algofrog.in" />
    <meta property="og:description" content="Comprehensive DSA interview preparation guide with 650+ problems across 43 topics." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://algofrog.in" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="DSA Mastery Guide — algofrog.in" />
    <meta name="twitter:description" content="650+ problems across 43 DSA topics for interview prep." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-RKMP4BG1N2"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-RKMP4BG1N2');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="app">
      <SidebarNav topics={topics} />

      <!-- MAIN -->
      <div class="main">
        <Topbar />

        <div class="content">
          {topics.map((topic) => <TopicCard topic={topic} />)}
        </div>
      </div>

      <button class="mob-nav-btn" id="mob-nav-btn" aria-label="Open navigation">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
    <script define:vars={{ topicMetas }}>
      // Theme Toggler (persists to localStorage)
      function toggleTheme() {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', newTheme);
        try {
          localStorage.setItem('theme', newTheme);
        } catch (e) {}
      }
      document.querySelectorAll('.theme-btn, .theme-btn-top').forEach((btn) => {
        btn.addEventListener('click', toggleTheme);
      });

      // Topic Switching
      const navItems = document.querySelectorAll('.nav-item');
      const topicCards = document.querySelectorAll('.topic-card');
      const topbarTitle = document.getElementById('topbar-title');
      const topbarMeta = document.getElementById('topbar-meta');

      navItems.forEach((item) => {
        item.addEventListener('click', () => {
          const topicNum = parseInt(item.getAttribute('data-topic-id'));
          show(topicNum, item);
        });
      });

      function show(topicNum, clickedItem) {
        // Update nav items
        navItems.forEach((item) => item.classList.remove('active'));
        clickedItem.classList.add('active');

        // Update topic cards
        topicCards.forEach((card) => card.classList.remove('active'));
        const activeCard = document.getElementById(`tp${topicNum}`);
        if (activeCard) {
          activeCard.classList.add('active');
        }

        // Update topbar
        const topicTitle = clickedItem.innerText.replace(/^\d+\s*/, '');
        topbarTitle.textContent = topicTitle;
        topbarMeta.textContent = topicMetas[topicNum] || '';

        // Close sidebar on mobile
        const sidebar = document.getElementById('sidebar');
        if (sidebar.classList.contains('open')) {
          sidebar.classList.remove('open');
        }
      }

      // Table Filtering — searches across ALL topics.
      // Empty query: restore normal single-topic view.
      // Non-empty: reveal every topic card that contains ≥1 matching row, hide non-matching rows.
      const searchInput = document.getElementById('searchInput');
      searchInput.addEventListener('input', filterTable);

      function filterTable() {
        const filter = searchInput.value.trim().toLowerCase();

        if (!filter) {
          // Reset: restore single-topic view — show only the active card, show every row.
          const activeNav = document.querySelector('.nav-item.active');
          topicCards.forEach((card) => {
            card.classList.remove('active');
            card.style.display = '';
            card.querySelectorAll('tr').forEach((tr) => (tr.style.display = ''));
          });
          if (activeNav) {
            const activeId = parseInt(activeNav.getAttribute('data-topic-id'));
            const activeCard = document.getElementById(`tp${activeId}`);
            if (activeCard) activeCard.classList.add('active');
            topbarTitle.textContent = activeNav.innerText.replace(/^\d+\s*/, '');
            topbarMeta.textContent = topicMetas[activeId] || '';
          }
          return;
        }

        let firstMatch = null;
        topicCards.forEach((card) => {
          const table = card.querySelector('table');
          if (!table) {
            card.style.display = 'none';
            return;
          }
          const rows = table.getElementsByTagName('tr');
          let cardHasMatch = false;
          for (let i = 1; i < rows.length; i++) {
            // skip header
            const txt = rows[i].innerText.toLowerCase();
            const match = txt.indexOf(filter) > -1;
            rows[i].style.display = match ? '' : 'none';
            if (match) cardHasMatch = true;
          }
          if (cardHasMatch) {
            card.classList.add('active');
            card.style.display = '';
            if (!firstMatch) firstMatch = card;
          } else {
            card.classList.remove('active');
            card.style.display = 'none';
          }
        });

        if (firstMatch) {
          const topicNum = firstMatch.id.replace('tp', '');
          topbarTitle.textContent = `Results for "${searchInput.value.trim()}"`;
          topbarMeta.textContent = topicMetas[topicNum] || '';
        } else {
          topbarTitle.textContent = `No matches for "${searchInput.value.trim()}"`;
          topbarMeta.textContent = '';
        }
      }

      // Mobile Nav
      const mobNavBtn = document.getElementById('mob-nav-btn');
      const sidebar = document.getElementById('sidebar');
      mobNavBtn.addEventListener('click', () => {
        sidebar.classList.toggle('open');
      });

      // Initialize first view
      document.addEventListener('DOMContentLoaded', () => {
        const firstNavItem = document.querySelector('.nav-item');
        if (firstNavItem) {
          const topicNum = parseInt(firstNavItem.getAttribute('data-topic-id'));
          show(topicNum, firstNavItem);
        }
      });
    </script>
  </body>
</html>

