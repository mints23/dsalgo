                        <tr><td>Median — lower half</td><td>Max-heap</td><td>Negate</td><td>Root = largest of lower half</td><td>Lower median</td></tr>
                        <tr><td>Median — upper half</td><td>Min-heap</td><td>heapq default</td><td>Root = smallest of upper half</td><td>Upper median</td></tr>
