<script>
    // Theme Toggler
    function toggleTheme() {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', newTheme);
    }
    document.querySelectorAll('.theme-btn, .theme-btn-top').forEach(btn => {
        btn.addEventListener('click', toggleTheme);
    });

    // Topic Switching
    const navItems = document.querySelectorAll('.nav-item');
    const topicCards = document.querySelectorAll('.topic-card');
    const topbarTitle = document.getElementById('topbar-title');
    const topbarMeta = document.getElementById('topbar-meta');

    const topicMetas = {
        1: 'Algorithms · Technique',
        2: 'Algorithms · Data Structure',
        3: 'Algorithms · Technique',
        4: 'Algorithms · Technique',
        5: 'Algorithms · Technique',
        6: 'Algorithms · Technique',
        7: 'Algorithms · Technique',
        8: 'Algorithms · Technique',
        9: 'Algorithms · Technique',
        10: 'Advanced Techniques · Number Theory',
        11: 'Advanced Techniques · Range Queries',
        12: 'Advanced Techniques · Range Queries',
        13: 'Advanced Techniques · String Matching',
        14: 'Advanced Techniques · Sequence',
        15: 'Data Structures · Technique',
        16: 'Data Structures · Technique',
        17: 'Data Structures · Structure',
        18: 'Data Structures · Structure',
        19: 'Graphs · Fundamentals',
        20: 'Graphs · Traversal',
        21: 'Graphs · Traversal',
        22: 'Graphs · Traversal',
        23: 'Graphs · Technique',
        24: 'Graphs · Technique',
        25: 'Graphs · Shortest Path',
        26: 'Graphs · Shortest Path',
        27: 'Graphs · Shortest Path',
        28: 'Graphs · Structure',
        29: 'Graphs · Advanced Overview',
        30: 'Dynamic Programming · 1D Linear DP',
        31: 'Dynamic Programming · 2D Grid DP',
        32: 'Dynamic Programming · Knapsack Family',
        33: 'Dynamic Programming · Strings & Subsequences',
        34: 'Dynamic Programming · State Machine DP',
        35: 'Dynamic Programming · Interval DP',
        36: 'Dynamic Programming · Partition DP',
        37: 'Dynamic Programming · Game Theory & Minimax',
        38: 'Dynamic Programming · Tree DP',
        39: 'Dynamic Programming · Digit DP',
        40: 'Dynamic Programming · DAGs & Probability',
        41: 'Dynamic Programming · Combinatorial & Modulo',
        42: 'Dynamic Programming · Data Structure Optimized'
    };

    navItems.forEach(item => {
        item.addEventListener('click', () => {
            const topicNum = parseInt(item.getAttribute('data-topic-id'));
            show(topicNum, item);
        });
    });

    function show(topicNum, clickedItem) {
        // Update nav items
        navItems.forEach(item => item.classList.remove('active'));
        clickedItem.classList.add('active');

        // Update topic cards
        topicCards.forEach(card => card.classList.remove('active'));
        const activeCard = document.getElementById(`tp${topicNum}`);
        if (activeCard) {
            activeCard.classList.add('active');
        }

        // Update topbar
        const topicTitle = clickedItem.innerText.replace(/^\\d+\\s*/, '');
        topbarTitle.textContent = topicTitle;
        topbarMeta.textContent = topicMetas[topicNum] || '';

        // Close sidebar on mobile
        const sidebar = document.getElementById('sidebar');
        if (sidebar.classList.contains('open')) {
            sidebar.classList.remove('open');
        }
    }

    // Table Filtering
    const searchInput = document.getElementById('searchInput');
    searchInput.addEventListener('input', filterTable);

    function filterTable() {
        const filter = searchInput.value.toLowerCase();
        const activeCard = document.querySelector('.topic-card.active');
        if (!activeCard) return;

        const table = activeCard.querySelector('table');
        if (!table) return;

        const rows = table.getElementsByTagName('tr');

        for (let i = 1; i < rows.length; i++) { // Start from 1 to skip header
            const cells = rows[i].getElementsByTagName('td');
            let shouldShow = false;
            for (let j = 0; j < cells.length; j++) {
                if (cells[j]) {
                    if (cells[j].innerText.toLowerCase().indexOf(filter) > -1) {
                        shouldShow = true;
                        break;
                    }
                }
            }
            rows[i].style.display = shouldShow ? '' : 'none';
        }
    }

    // Mobile Nav
    const mobNavBtn = document.getElementById('mob-nav-btn');
    const sidebar = document.getElementById('sidebar');
    mobNavBtn.addEventListener('click', () => {
        sidebar.classList.toggle('open');
    });

    // Initialize first view
    document.addEventListener('DOMContentLoaded', () => {
        const firstNavItem = document.querySelector('.nav-item');
        if(firstNavItem) {
           const topicNum = parseInt(firstNavItem.getAttribute('data-topic-id'));
           show(topicNum, firstNavItem);
        }
    });
</script>
