---
/**
 * Login page only. Preview drawer uses `login-sneak-static` — not imported by `index.astro` or the app shell.
 */
import '../styles/global.css';
import {
  LOGIN_SNEAK_NAV,
  LOGIN_SNEAK_SAMPLE_TOPIC,
  LOGIN_SNEAK_SAMPLE_ROWS,
  type LoginSneakNavRow,
} from '../data/login-sneak-static';

const sectionOrder = [
  'Algorithms',
  'Data Structures',
  'Dynamic Programming',
  'Graphs',
  'Advanced Techniques',
];

const sidebarTopicCount = LOGIN_SNEAK_NAV.length;

const grouped = new Map<string, LoginSneakNavRow[]>();
for (const t of LOGIN_SNEAK_NAV) {
  const arr = grouped.get(t.navSection) ?? [];
  arr.push(t);
  grouped.set(t.navSection, arr);
}

const sections = sectionOrder.filter((s) => grouped.has(s)).concat(
  [...grouped.keys()].filter((s) => !sectionOrder.includes(s)),
);

type SneakItem =
  | { kind: 'section'; label: string; stagger: number }
  | { kind: 'topic'; topic: LoginSneakNavRow; stagger: number };

const sneakItems: SneakItem[] = [];
let rawStagger = 0;
for (const section of sections) {
  sneakItems.push({
    kind: 'section',
    label: section,
    stagger: Math.min(rawStagger++, 24),
  });
  for (const t of grouped.get(section)!) {
    sneakItems.push({
      kind: 'topic',
      topic: t,
      stagger: Math.min(rawStagger++, 24),
    });
  }
}

const tableStaggerBase = 26;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in — DSA Mastery Guide · algofrog.in</title>
    <meta
      name="description"
      content="Sign in to the DSA Mastery Guide: structured interview prep, topic roadmap, and problem tables. Secure access with email or Google / GitHub."
    />
    <meta name="theme-color" content="#01696f" />
    <link rel="canonical" href="https://algofrog.in/login" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@300..700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      /* Login route only — scoped to this HTML file; does not ship on `/` */
      .login-page {
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        position: relative;
      }
      .login-card-centre {
        width: 100%;
        max-width: 400px;
        flex-shrink: 0;
      }

      /* ── Tantalizing peek tab (fixed left) ── */
      .login-peek-tab {
        position: fixed;
        left: 0;
        top: 50%;
        z-index: 60;
        transform: translateY(-50%);
        display: flex;
        align-items: center;
        gap: 0.45rem;
        max-width: min(11.5rem, 38vw);
        padding: 0.65rem 0.75rem 0.65rem 0.55rem;
        margin: 0;
        border: 1px solid color-mix(in srgb, var(--primary) 35%, var(--border));
        border-left: none;
        border-radius: 0 0.9rem 0.9rem 0;
        background: linear-gradient(
          135deg,
          color-mix(in srgb, var(--primary) 18%, var(--surface)),
          color-mix(in srgb, var(--primary) 6%, var(--bg))
        );
        box-shadow:
          0 4px 20px color-mix(in srgb, var(--primary) 18%, transparent),
          inset 0 1px 0 color-mix(in srgb, #fff 25%, transparent);
        cursor: pointer;
        text-align: left;
        font: inherit;
        color: var(--text);
        transition:
          transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
          box-shadow 0.2s ease,
          filter 0.2s ease;
        animation: login-peek-glow 3.2s ease-in-out infinite;
      }
      [data-theme='dark'] .login-peek-tab {
        box-shadow:
          0 4px 24px rgba(0, 0, 0, 0.35),
          inset 0 1px 0 color-mix(in srgb, #fff 8%, transparent);
      }
      .login-peek-tab:hover {
        filter: brightness(1.03);
        box-shadow:
          0 6px 28px color-mix(in srgb, var(--primary) 28%, transparent),
          inset 0 1px 0 color-mix(in srgb, #fff 30%, transparent);
      }
      .login-peek-tab:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 3px;
      }
      .login-page.peek-open .login-peek-tab {
        transform: translateY(-50%) translateX(-120%);
        opacity: 0;
        pointer-events: none;
      }
      .login-peek-tab-emoji {
        font-size: 1.15rem;
        line-height: 1;
        flex-shrink: 0;
        animation: login-peek-sparkle 2.8s ease-in-out infinite;
      }
      @keyframes login-peek-sparkle {
        0%,
        100% {
          transform: scale(1) rotate(-4deg);
          filter: brightness(1);
        }
        50% {
          transform: scale(1.08) rotate(4deg);
          filter: brightness(1.15);
        }
      }
      @keyframes login-peek-glow {
        0%,
        100% {
          box-shadow:
            0 4px 20px color-mix(in srgb, var(--primary) 18%, transparent),
            inset 0 1px 0 color-mix(in srgb, #fff 25%, transparent);
        }
        50% {
          box-shadow:
            0 6px 26px color-mix(in srgb, var(--primary) 32%, transparent),
            inset 0 1px 0 color-mix(in srgb, #fff 35%, transparent);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .login-peek-tab {
          animation: none;
        }
        .login-peek-tab-emoji {
          animation: none;
        }
        .login-page.peek-open .login-peek-tab {
          transition: opacity 0.2s ease;
        }
      }
      .login-peek-tab-lines {
        display: flex;
        flex-direction: column;
        gap: 0.12rem;
        min-width: 0;
      }
      .login-peek-tab-title {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.2;
        color: var(--text);
      }
      .login-peek-tab-sub {
        font-size: 0.6rem;
        font-weight: 600;
        color: var(--primary);
        letter-spacing: 0.02em;
        line-height: 1.25;
      }
      .login-peek-tab-arrow {
        flex-shrink: 0;
        font-size: 1rem;
        font-weight: 800;
        color: var(--primary);
        opacity: 0.9;
      }

      .login-peek-backdrop {
        position: fixed;
        inset: 0;
        z-index: 70;
        background: color-mix(in srgb, var(--text) 22%, transparent);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s ease;
      }
      .login-peek-backdrop.is-open {
        opacity: 1;
        pointer-events: auto;
      }

      .login-peek-drawer {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 80;
        width: min(26.5rem, 92vw);
        max-width: 100%;
        background: var(--bg);
        border-right: 1px solid var(--border);
        box-shadow: 8px 0 40px color-mix(in srgb, var(--text) 12%, transparent);
        transform: translateX(-105%);
        transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
        display: flex;
        flex-direction: column;
        min-height: 0;
      }
      .login-peek-drawer.is-open {
        transform: translateX(0);
      }
      @media (prefers-reduced-motion: reduce) {
        .login-peek-drawer {
          transition-duration: 0.15s;
        }
      }
      .login-peek-drawer-top {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.65rem 0.75rem 0.65rem 1rem;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
      }
      .login-peek-drawer-title {
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--text);
      }
      .login-peek-drawer-close {
        flex-shrink: 0;
        width: 2rem;
        height: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 0.4rem;
        background: var(--offset);
        color: var(--muted);
        font-size: 1.2rem;
        line-height: 1;
        cursor: pointer;
        transition: background 0.12s, color 0.12s;
      }
      .login-peek-drawer-close:hover {
        background: var(--divider);
        color: var(--text);
      }
      .login-peek-drawer-body {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        padding: 0.5rem 0.85rem 1.25rem;
        -webkit-overflow-scrolling: touch;
      }
      .login-peek-drawer-body .login-sneak {
        border: none;
        box-shadow: none;
        background: transparent;
        padding: 0.35rem 0 0;
      }
      .login-peek-drawer-body .login-sneak::before {
        display: none;
      }
      .login-card {
        width: 100%;
        max-width: 400px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 2.5rem 2rem 2rem;
      }
      .login-trust-strip {
        margin-bottom: 1rem;
        padding: 0.65rem 0.8rem;
        border-radius: 0.5rem;
        background: color-mix(in srgb, var(--primary) 7%, var(--surface2));
        border: 1px solid color-mix(in srgb, var(--primary) 16%, var(--border));
      }
      .login-trust-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        font-size: 0.72rem;
        line-height: 1.45;
        color: var(--muted);
      }
      .login-trust-list li {
        padding-left: 1.05rem;
        position: relative;
      }
      .login-trust-list li::before {
        content: '✓';
        position: absolute;
        left: 0;
        top: 0.05rem;
        font-size: 0.62rem;
        color: var(--primary);
        font-weight: 800;
      }
      .login-trust-list strong {
        color: var(--text);
        font-weight: 600;
      }
      .login-trust-list a {
        color: var(--primary);
        font-weight: 600;
        text-decoration: none;
      }
      .login-trust-list a:hover {
        text-decoration: underline;
      }
      .login-trust-peek-btn {
        display: inline;
        padding: 0;
        margin: 0;
        border: none;
        background: none;
        font: inherit;
        font-weight: 700;
        color: var(--primary);
        cursor: pointer;
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .login-trust-peek-btn:hover {
        color: var(--primary-h);
      }
      .login-card-footer {
        margin-top: 1.35rem;
        padding-top: 1rem;
        border-top: 1px solid var(--divider);
        font-size: 0.68rem;
        color: var(--faint);
        text-align: center;
        line-height: 1.4;
      }
      .login-card-footer a {
        color: var(--muted);
        font-weight: 500;
        text-decoration: none;
      }
      .login-card-footer a:hover {
        color: var(--primary);
        text-decoration: underline;
      }
      .login-logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 1.35rem;
        justify-content: center;
      }
      .login-logo-text {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
      }
      .login-logo-sub {
        font-size: 0.7rem;
        color: var(--muted);
      }
      .login-tabs {
        display: flex;
        border-bottom: 1px solid var(--divider);
        margin-bottom: 1.5rem;
      }
      .login-tab {
        flex: 1;
        padding: 0.6rem 0;
        text-align: center;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        border-bottom: 2px solid transparent;
        transition: color 0.15s, border-color 0.15s;
        background: none;
        border-top: none;
        border-left: none;
        border-right: none;
      }
      .login-tab.active {
        color: var(--primary);
        border-bottom-color: var(--primary);
      }
      .login-tab:hover {
        color: var(--text);
      }
      .form-group {
        margin-bottom: 1rem;
      }
      .form-group label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--muted);
        margin-bottom: 0.35rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .form-group input {
        width: 100%;
        padding: 0.6rem 0.75rem;
        border: 1px solid var(--border);
        border-radius: 0.4rem;
        background: var(--bg);
        color: var(--text);
        font-family: inherit;
        font-size: 0.85rem;
        outline: none;
        transition: border-color 0.15s;
      }
      .form-group input:focus {
        border-color: var(--primary);
      }
      .login-btn {
        width: 100%;
        padding: 0.65rem;
        border-radius: 0.4rem;
        background: var(--primary);
        color: var(--inv);
        font-weight: 600;
        font-size: 0.85rem;
        border: none;
        cursor: pointer;
        transition: background 0.15s;
        margin-top: 0.5rem;
      }
      .login-btn:hover {
        background: var(--primary-h);
      }
      .login-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
      .divider-row {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin: 1.25rem 0;
        color: var(--faint);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .divider-row--oauth {
        margin: 0.35rem 0 0.55rem;
      }
      .divider-row--email {
        margin: 0.75rem 0 1rem;
      }
      .login-oauth-first .oauth-btn:last-of-type {
        margin-bottom: 0;
      }
      .divider-row::before,
      .divider-row::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--divider);
      }
      .oauth-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.6rem;
        border: 1px solid var(--border);
        border-radius: 0.4rem;
        background: var(--surface2);
        color: var(--text);
        font-size: 0.82rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        margin-bottom: 0.6rem;
      }
      .oauth-btn:hover {
        background: var(--offset);
        border-color: var(--primary);
      }
      .oauth-btn svg {
        flex-shrink: 0;
      }
      .login-msg {
        font-size: 0.78rem;
        padding: 0.55rem 0.75rem;
        border-radius: 0.4rem;
        margin-bottom: 1rem;
        display: none;
      }
      .login-msg.error {
        display: block;
        background: color-mix(in oklab, var(--error) 12%, var(--bg));
        color: var(--error);
        border: 1px solid color-mix(in oklab, var(--error) 25%, var(--border));
      }
      .login-msg.success {
        display: block;
        background: color-mix(in oklab, var(--primary) 12%, var(--bg));
        color: var(--primary);
        border: 1px solid color-mix(in oklab, var(--primary) 25%, var(--border));
      }
      .theme-toggle-login {
        position: fixed;
        top: 1rem;
        right: 1rem;
        padding: 0.5rem;
        border-radius: 0.4rem;
        color: var(--muted);
        transition: color 0.15s;
      }
      .theme-toggle-login:hover {
        color: var(--text);
      }

      .login-sneak {
        position: relative;
        background: color-mix(in srgb, var(--surface) 72%, var(--bg));
        border: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
        border-radius: 1rem;
        padding: 1.35rem 1.35rem 1.2rem;
        min-width: 0;
        box-shadow: 0 1px 0 color-mix(in srgb, var(--primary) 12%, transparent);
      }
      .login-sneak::before {
        content: '';
        position: absolute;
        left: 1rem;
        right: 1rem;
        top: 0;
        height: 3px;
        border-radius: 0 0 3px 3px;
        background: linear-gradient(
          90deg,
          color-mix(in srgb, var(--primary) 45%, transparent),
          color-mix(in srgb, var(--primary) 15%, transparent)
        );
        opacity: 0.85;
      }
      .login-sneak-kicker {
        display: inline-block;
        font-size: 0.6rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--primary);
        background: color-mix(in srgb, var(--primary) 9%, var(--bg));
        border: 1px solid color-mix(in srgb, var(--primary) 18%, var(--border));
        padding: 0.2rem 0.5rem;
        border-radius: 999px;
        margin-bottom: 0.55rem;
      }
      .login-sneak-title {
        font-size: 1.15rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        margin-bottom: 0.4rem;
        line-height: 1.2;
        color: var(--text);
      }
      .login-sneak-sub {
        font-size: 0.78rem;
        color: var(--muted);
        line-height: 1.5;
        margin-bottom: 1rem;
        font-weight: 400;
      }
      .login-sneak-sub strong {
        color: var(--text);
        font-weight: 600;
      }

      .login-sneak-scroll {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.1rem 0.5rem;
        max-height: min(38vh, 280px);
        overflow-y: auto;
        padding: 0.5rem 0.4rem 0.5rem 0;
        margin-bottom: 1.15rem;
        scrollbar-width: thin;
        scrollbar-color: color-mix(in srgb, var(--primary) 25%, var(--divider)) transparent;
      }
      @media (max-width: 520px) {
        .login-sneak-scroll {
          grid-template-columns: 1fr;
        }
      }

      .login-sneak-sec {
        grid-column: 1 / -1;
        font-size: 0.58rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--muted);
        padding: 0.5rem 0.25rem 0.15rem;
        margin-top: 0.1rem;
        border-bottom: 1px solid color-mix(in srgb, var(--divider) 55%, transparent);
      }
      .login-sneak-sec:first-child {
        padding-top: 0;
        margin-top: 0;
      }

      .login-sneak-topic {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.32rem 0.4rem;
        border-radius: 0.45rem;
        font-size: 0.7rem;
        color: var(--text);
        transition: background 0.12s ease;
      }
      .login-sneak-topic:hover {
        background: color-mix(in srgb, var(--primary) 6%, var(--surface));
      }
      .login-sneak-topic-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.62rem;
        font-weight: 600;
        color: color-mix(in srgb, var(--muted) 85%, var(--primary));
        min-width: 1.25rem;
      }
      .login-sneak-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        margin-left: auto;
        flex-shrink: 0;
        box-shadow: 0 0 0 1px color-mix(in srgb, var(--border) 80%, transparent);
      }

      @keyframes login-sneak-rise {
        from {
          opacity: 0;
          transform: translateY(5px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .login-sneak-anim {
        opacity: 0;
        animation: login-sneak-rise 0.38s cubic-bezier(0.25, 0.9, 0.35, 1) forwards;
        animation-delay: calc(var(--s, 0) * 18ms);
      }
      @media (prefers-reduced-motion: reduce) {
        .login-sneak-anim {
          animation: none;
          opacity: 1;
          transform: none;
        }
      }

      .login-sneak-sample-h {
        font-size: 0.58rem;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 0.35rem;
      }
      .login-sneak-sample-title {
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 0.2rem;
        letter-spacing: -0.02em;
        color: var(--text);
      }
      .login-sneak-sample-meta {
        font-size: 0.72rem;
        color: var(--muted);
        margin-bottom: 0.7rem;
        line-height: 1.4;
      }
      .login-sneak-tbl-wrap {
        overflow-x: auto;
        border-radius: 0.55rem;
        border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
        background: color-mix(in srgb, var(--surface) 55%, var(--bg));
      }
      .login-sneak table {
        font-size: 0.65rem;
        margin: 0;
      }
      .login-sneak table th,
      .login-sneak table td {
        padding: 0.38rem 0.42rem;
        border-bottom: 1px solid color-mix(in srgb, var(--divider) 70%, transparent);
      }
      .login-sneak table thead th {
        font-size: 0.57rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
        background: transparent;
      }
      .login-sneak table tbody tr:hover {
        background: color-mix(in srgb, var(--primary) 5%, transparent);
      }
      .login-sneak table tbody tr:last-child td {
        border-bottom: none;
      }
      .login-sneak-foot {
        font-size: 0.68rem;
        color: var(--muted);
        margin-top: 0.75rem;
        line-height: 1.45;
        padding-top: 0.65rem;
        border-top: 1px dashed color-mix(in srgb, var(--divider) 85%, transparent);
      }
    </style>
  </head>
  <body>
    <div class="login-page" id="login-page-root">
      <button class="theme-toggle-login" id="theme-toggle-login" aria-label="Toggle theme">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
      </button>

      <button
        type="button"
        class="login-peek-tab"
        id="login-peek-open"
        aria-expanded="false"
        aria-controls="login-peek-drawer"
      >
        <span class="login-peek-tab-emoji" aria-hidden="true">✨</span>
        <span class="login-peek-tab-lines">
          <span class="login-peek-tab-title">What’s in the guide?</span>
          <span class="login-peek-tab-sub">{sidebarTopicCount} topics · sample problems — no login</span>
        </span>
        <span class="login-peek-tab-arrow" aria-hidden="true">›</span>
      </button>

      <div class="login-peek-backdrop" id="login-peek-backdrop" aria-hidden="true"></div>

      <div
        class="login-peek-drawer"
        id="login-peek-drawer"
        role="dialog"
        aria-modal="true"
        aria-labelledby="login-peek-heading"
        aria-hidden="true"
      >
        <div class="login-peek-drawer-top">
          <span class="login-peek-drawer-title" id="login-peek-heading">Peek inside — static preview</span>
          <button type="button" class="login-peek-drawer-close" id="login-peek-close" aria-label="Close preview">
            ×
          </button>
        </div>
        <div class="login-peek-drawer-body">
          <aside class="login-sneak" aria-label="Static curriculum preview">
            <p class="login-sneak-kicker">Ships with this page · zero API calls</p>
            <h2 class="login-sneak-title">Your roadmap, before you sign in</h2>
            <p class="login-sneak-sub">
              Every topic below matches the live app. Plus a few real rows from
              <strong>{LOGIN_SNEAK_SAMPLE_TOPIC.title}</strong>
              ({LOGIN_SNEAK_SAMPLE_TOPIC.summaryMeta.split('·')[0]?.trim()}).
            </p>

            <div class="login-sneak-scroll">
              {
                sneakItems.map((item) =>
                  item.kind === 'section' ? (
                    <div class="login-sneak-sec login-sneak-anim" style={`--s:${item.stagger}`}>
                      {item.label}
                    </div>
                  ) : (
                    <div class="login-sneak-topic login-sneak-anim" style={`--s:${item.stagger}`}>
                      <span class="login-sneak-topic-num">{item.topic.displayNumber}</span>
                      <span>{item.topic.navLabel}</span>
                      <span class="login-sneak-dot" style={`background:${item.topic.navTierDotColor}`} />
                    </div>
                  ),
                )
              }
            </div>

            <p class="login-sneak-sample-h">Sample problem rows</p>
            <h3 class="login-sneak-sample-title">{LOGIN_SNEAK_SAMPLE_TOPIC.title}</h3>
            <p class="login-sneak-sample-meta">{LOGIN_SNEAK_SAMPLE_TOPIC.summaryMeta}</p>
            <div class="login-sneak-tbl-wrap">
              <table>
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Layer</th>
                    <th>Link</th>
                    <th>Problem</th>
                    <th>Diff</th>
                    <th>Key insight</th>
                  </tr>
                </thead>
                <tbody>
                  {
                    LOGIN_SNEAK_SAMPLE_ROWS.map((p, i) => (
                      <tr class="login-sneak-anim" style={`--s:${tableStaggerBase + i}`}>
                        <td class="num-cell">{p.num}</td>
                        <td>
                          <span class={p.layerCls}>{p.layer}</span>
                        </td>
                        <td>
                          <a class="lc-link" href={p.href} target="_blank" rel="noopener noreferrer">
                            LC {p.lc}
                          </a>
                        </td>
                        <td class="prob-name">{p.name}</td>
                        <td>
                          <span class={p.diffCls}>{p.diff}</span>
                        </td>
                        <td class="insight">{p.insight}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
            <p class="login-sneak-foot">
              After sign-in: full tables, progress, study modes, and walkthroughs where we ship them.
            </p>
          </aside>
        </div>
      </div>

      <main class="login-card-centre" id="main-content">
      <div class="login-card">
        <div class="login-logo">
          <svg width="28" height="28" viewBox="0 0 100 100" fill="none">
            <circle cx="50" cy="50" r="46" stroke="var(--primary)" stroke-width="5" />
            <text x="50" y="62" text-anchor="middle" font-size="38" font-weight="700" fill="var(--primary)" font-family="Inter, sans-serif">af</text>
          </svg>
          <div>
            <div class="login-logo-text">algofrog.in</div>
            <div class="login-logo-sub">DSA Mastery Guide</div>
          </div>
        </div>

        <div class="login-trust-strip">
          <ul class="login-trust-list">
            <li>
              <strong>New accounts</strong> get a <strong>7-day trial</strong> with full access to the guide.
            </li>
            <li>
              <strong>Curious about the curriculum?</strong>
              <button type="button" class="login-trust-peek-btn" id="login-trust-open-peek" aria-controls="login-peek-drawer">
                Open the static preview
              </button>
              — topic list and sample rows match the live guide structure.
            </li>
            <li>
              Questions:
              <a href="mailto:algofrog07@gmail.com?subject=DSA%20Mastery%20Guide%20%E2%80%94%20question">algofrog07@gmail.com</a>
            </li>
          </ul>
        </div>

        <div class="divider-row divider-row--oauth">Continue with</div>

        <div class="login-oauth-first">
          <button type="button" class="oauth-btn" id="google-btn" aria-label="Continue with Google">
            <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A11.96 11.96 0 0 0 1 12c0 1.93.46 3.77 1.18 5.43l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google
          </button>

          <button type="button" class="oauth-btn" id="github-btn" aria-label="Continue with GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </button>
        </div>

        <div class="divider-row divider-row--email">Or email</div>

        <div class="login-tabs" role="tablist" aria-label="Account access">
          <button
            type="button"
            class="login-tab active"
            id="tab-signin"
            role="tab"
            aria-selected="true"
            aria-controls="signin-panel"
            tabindex="0"
          >
            Sign in
          </button>
          <button
            type="button"
            class="login-tab"
            id="tab-signup"
            role="tab"
            aria-selected="false"
            aria-controls="signup-panel"
            tabindex="-1"
          >
            Sign up
          </button>
        </div>

        <div id="login-msg" class="login-msg"></div>

        <!-- Sign In Form -->
        <div id="signin-panel" role="tabpanel" aria-labelledby="tab-signin">
        <form id="signin-form" autocomplete="on">
          <div class="form-group">
            <label for="signin-email">Email</label>
            <input type="email" id="signin-email" name="email" required autocomplete="email" placeholder="you@example.com" />
          </div>
          <div class="form-group">
            <label for="signin-password">Password</label>
            <input type="password" id="signin-password" name="password" required autocomplete="current-password" placeholder="Your password" />
          </div>
          <button type="submit" class="login-btn" id="signin-btn">Sign in</button>
        </form>
        </div>

        <!-- Sign Up Form -->
        <div id="signup-panel" role="tabpanel" aria-labelledby="tab-signup" hidden>
        <form id="signup-form" autocomplete="on">
          <div class="form-group">
            <label for="signup-name">Full Name</label>
            <input type="text" id="signup-name" name="name" required autocomplete="name" placeholder="Your name" />
          </div>
          <div class="form-group">
            <label for="signup-email">Email</label>
            <input type="email" id="signup-email" name="email" required autocomplete="email" placeholder="you@example.com" />
          </div>
          <div class="form-group">
            <label for="signup-password">Password</label>
            <input type="password" id="signup-password" name="password" required autocomplete="new-password" placeholder="Min 6 characters" minlength="6" />
          </div>
          <button type="submit" class="login-btn" id="signup-btn">Create account</button>
        </form>
        </div>

        <p class="login-card-footer">
          <a href="https://algofrog.in/">algofrog.in</a>
          · DSA Mastery Guide
          · © 2026
        </p>

      </div>
      </main>
    </div>

    <script>
      import { supabase } from '../lib/supabase';

      // If already logged in, redirect to home
      const { data: { session } } = await supabase.auth.getSession();
      if (session) {
        window.location.href = '/';
      }

      /** Clears preview-only UI so it never leaves `body` locked or overlays active after navigation. */
      function resetLoginPreviewChrome() {
        try {
          document.body.style.overflow = '';
          document.getElementById('login-page-root')?.classList.remove('peek-open');
          document.getElementById('login-peek-drawer')?.classList.remove('is-open');
          document.getElementById('login-peek-backdrop')?.classList.remove('is-open');
          const openBtn = document.getElementById('login-peek-open');
          const drawer = document.getElementById('login-peek-drawer');
          const backdrop = document.getElementById('login-peek-backdrop');
          openBtn?.setAttribute('aria-expanded', 'false');
          drawer?.setAttribute('aria-hidden', 'true');
          backdrop?.setAttribute('aria-hidden', 'true');
        } catch {
          document.body.style.overflow = '';
        }
      }

      /** Optional preview: failures here must not block sign-in / OAuth. */
      function initLoginPreviewOptional() {
        const loginPageRoot = document.getElementById('login-page-root');
        const peekDrawer = document.getElementById('login-peek-drawer');
        const peekBackdrop = document.getElementById('login-peek-backdrop');
        const peekOpen = document.getElementById('login-peek-open');
        const peekClose = document.getElementById('login-peek-close');
        if (!loginPageRoot || !peekDrawer || !peekBackdrop || !peekOpen || !peekClose) return;

        function openPeek() {
          try {
            peekDrawer.classList.add('is-open');
            peekBackdrop.classList.add('is-open');
            loginPageRoot.classList.add('peek-open');
            document.body.style.overflow = 'hidden';
            peekOpen.setAttribute('aria-expanded', 'true');
            peekDrawer.setAttribute('aria-hidden', 'false');
            peekBackdrop.setAttribute('aria-hidden', 'false');
            peekClose.focus();
          } catch {
            resetLoginPreviewChrome();
          }
        }

        function closePeek() {
          try {
            peekDrawer.classList.remove('is-open');
            peekBackdrop.classList.remove('is-open');
            loginPageRoot.classList.remove('peek-open');
            document.body.style.overflow = '';
            peekOpen.setAttribute('aria-expanded', 'false');
            peekDrawer.setAttribute('aria-hidden', 'true');
            peekBackdrop.setAttribute('aria-hidden', 'true');
            peekOpen.focus();
          } catch {
            resetLoginPreviewChrome();
          }
        }

        peekOpen.addEventListener('click', () => openPeek());
        document.getElementById('login-trust-open-peek')?.addEventListener('click', () => openPeek());
        peekBackdrop.addEventListener('click', () => closePeek());
        peekClose.addEventListener('click', () => closePeek());
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && peekDrawer.classList.contains('is-open')) {
            e.preventDefault();
            closePeek();
          }
        });
        window.addEventListener('pagehide', resetLoginPreviewChrome);
      }

      initLoginPreviewOptional();

      // Tab switching
      const tabSignin = document.getElementById('tab-signin')!;
      const tabSignup = document.getElementById('tab-signup')!;
      const signinPanel = document.getElementById('signin-panel')!;
      const signupPanel = document.getElementById('signup-panel')!;
      const signinForm = document.getElementById('signin-form') as HTMLFormElement;
      const signupForm = document.getElementById('signup-form') as HTMLFormElement;
      const msgEl = document.getElementById('login-msg')!;

      function showMsg(text: string, type: 'error' | 'success') {
        msgEl.textContent = text;
        msgEl.className = `login-msg ${type}`;
      }
      function clearMsg() {
        msgEl.className = 'login-msg';
        msgEl.textContent = '';
      }

      tabSignin.addEventListener('click', () => {
        tabSignin.classList.add('active');
        tabSignup.classList.remove('active');
        tabSignin.setAttribute('aria-selected', 'true');
        tabSignup.setAttribute('aria-selected', 'false');
        tabSignin.tabIndex = 0;
        tabSignup.tabIndex = -1;
        signinPanel.hidden = false;
        signupPanel.hidden = true;
        clearMsg();
      });
      tabSignup.addEventListener('click', () => {
        tabSignup.classList.add('active');
        tabSignin.classList.remove('active');
        tabSignup.setAttribute('aria-selected', 'true');
        tabSignin.setAttribute('aria-selected', 'false');
        tabSignup.tabIndex = 0;
        tabSignin.tabIndex = -1;
        signinPanel.hidden = true;
        signupPanel.hidden = false;
        clearMsg();
      });

      // Sign In
      signinForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearMsg();
        const btn = document.getElementById('signin-btn') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Signing in…';

        const email = (document.getElementById('signin-email') as HTMLInputElement).value;
        const password = (document.getElementById('signin-password') as HTMLInputElement).value;

        const { error } = await supabase.auth.signInWithPassword({ email, password });

        if (error) {
          showMsg(error.message, 'error');
          btn.disabled = false;
          btn.textContent = 'Sign in';
        } else {
          resetLoginPreviewChrome();
          window.location.href = '/';
        }
      });

      // Sign Up
      signupForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearMsg();
        const btn = document.getElementById('signup-btn') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Creating account…';

        const email = (document.getElementById('signup-email') as HTMLInputElement).value;
        const password = (document.getElementById('signup-password') as HTMLInputElement).value;

        const name = (document.getElementById('signup-name') as HTMLInputElement).value.trim();

        const { data, error } = await supabase.auth.signUp({
          email,
          password,
          options: { data: { full_name: name } },
        });

        if (error) {
          showMsg(error.message, 'error');
        } else if (data.user && data.user.identities && data.user.identities.length === 0) {
          showMsg('An account with this email already exists. Please sign in instead.', 'error');
        } else {
          showMsg('Check your email for a confirmation link!', 'success');
        }
        btn.disabled = false;
        btn.textContent = 'Create account';
      });

      // Google OAuth
      document.getElementById('google-btn')!.addEventListener('click', async () => {
        await supabase.auth.signInWithOAuth({
          provider: 'google',
          options: {
            redirectTo: window.location.origin + '/',
            queryParams: { prompt: 'select_account' },
          },
        });
      });


      // GitHub OAuth
      document.getElementById('github-btn')!.addEventListener('click', async () => {
        await supabase.auth.signInWithOAuth({
          provider: 'github',
          options: { redirectTo: window.location.origin + '/' },
        });
      });

      // Theme toggle
      document.getElementById('theme-toggle-login')!.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch (e) {}
      });
    </script>
  </body>
</html>
